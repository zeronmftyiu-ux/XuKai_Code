/* pages/record/record.wxss */
page {
    background: #F3F5F7;
  }
  .page-container-margin{
    height: 100%;
    width: 690rpx;
    margin: 0 auto;
  }
  .content-card{
    position: relative;
    margin-top: 44rpx;
    width: 688rpx;
    height: 417rpx;
  }
  .content-image{
    position: absolute;
    width: 100%;
    height: 100%;
  }
  .content-point-content{
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .content-point-title{
    font-family: PingFangSC-Regular;
    font-size: 24rpx;
    color: #FFFFFF;
    font-weight: 400;
    line-height: 24rpx;
  }
  .content-point{
    font-family: DINAlternate-Bold;
    font-size: 64rpx;
    color: #FFFFFF;
    font-weight: 700;
    line-height: 1.1;
    margin-top: 12rpx;
  }
  
  .content-point-history{
    margin-top: 70rpx;
    display: flex;
    justify-content: space-between;
    margin-left: 47rpx;
    margin-right: 150rpx;
  }
  .content-point-tip{
    position: absolute;
    bottom: 50rpx;
    font-family: PingFangSC-Regular;
    font-size: 22rpx;
    color: #0082A6;
    font-weight: 400;
    margin-left: 47rpx;
  }
  .record-list{
    background: #FFFFFF;
    border-radius: 10rpx;
    display: flex;
    flex-direction: column;
    width: 100%;
    padding-bottom: 40rpx;
  }
  .record-list-content{
    margin-left: 25rpx;
    margin-right: 25rpx;
    margin-top: 38rpx;
  }
  .record-list-title-view{
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20rpx;
  }
  .record-list-title {
    font-family: PingFangSC-Semibold;
    font-size: 36rpx;
    color: #000000;
    letter-spacing: 0;
    font-weight: 600;
  }
  
  .record-list-date-view{
    display: flex;
    align-items: center;
  }
  .record-list-date{
    font-family: PingFangSC-Regular;
    font-size: 28rpx;
    color: rgba(0, 0, 0, 0.65);
    font-weight: 400;
    margin-right: 10rpx;
  }
  
  .record-content-upload-tip-view{
    position: relative;
    height: 60rpx;
    background: #FFF6E8;
    border-radius: 8rpx;
    margin-top: 25rpx;
    display: flex;
    align-items: center;
  }
  .record-content-upload-tip-image{
    margin-left: 10rpx;
    width: 48rpx;
    height: 48rpx;
  }
  .record-content-upload-tip{
    font-family: PingFangSC-Regular;
    font-size: 24rpx;
    color: #FF9419;
    letter-spacing: 0;
    font-weight: 400;
    margin-left: 10rpx;
  }
  .record-content-upload-button{
    position: absolute;
    right: 10rpx;
    font-family: PingFangSC-Regular;
    font-size: 24rpx;
    color: #FF9419;
    letter-spacing: 0;
    font-weight: 400;
  }
  .record-list-content-item{
    position: relative;
    display: flex;
    align-items: center;
    height: 140rpx;
  }
  .record-list-item-coin{
    width: 56rpx;
    height: 56rpx;
  }
  .record-list-content-item-info{
    display: flex;
    flex-direction: column; 
    margin-left: 20rpx;
  }
  .record-list-content-item-info-content {
    display: flex;
    align-items: center;
  }
  .record-list-content-item-info-title{
    font-family: PingFangTC-Regular;
    font-size: 30rpx;
    color: rgba(0,0,0,0.85);
    letter-spacing: 0;
    font-weight: 400;
  }
  .record-list-content-item-info-appname{
    border: 1px solid rgba(6,161,209,1);
    border-radius: 8rpx;
    font-family: PingFangTC-Regular;
    font-size: 20rpx;
    color: #059CCB;
    letter-spacing: 0;
    font-weight: 400;
    line-height: 34rpx;
    margin-left: 16rpx;
    padding-left: 8rpx;
    padding-right: 8rpx;
  }
  .record-list-content-item-info-time{
    font-family: PingFangSC-Regular;
    font-size: 24rpx;
    color: rgba(0,0,0,0.45);
    letter-spacing: 0;
    font-weight: 400;
    margin-top: 8rpx;
  }
  .record-list-content-item-score{
    position: absolute;
    right: 0;
    font-family: DIN-Medium;
    font-size: 38rpx;
    color: rgba(26,148,255,0.80);
    letter-spacing: 0;
    font-weight: 500;
  }
  