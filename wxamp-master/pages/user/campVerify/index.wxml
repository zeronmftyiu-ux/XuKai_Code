<view class="verify-page">
  <view class="verify-card">
    <view class="verify-title">{{mode === 'change' ? '更换绑定手机号' : '绑定活动'}}</view>
    <view class="verify-desc">
      {{mode === 'change' ? '请输入新的手机号和验证码' : '请输入手机号和验证码完成活动绑定'}}
    </view>

    <view class="form-item">
      <view class="label">手机号</view>
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{mobile}}"
        bindinput="onInputMobile"
      />
      <view class="form-tip">mock 调试时请输入 123456 作为验证码</view>
    </view>

    <view class="form-item">
      <view class="label">验证码</view>
      <view class="code-row">
        <input
          class="input code-input"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          value="{{code}}"
          bindinput="onInputCode"
        />
        <view class="code-btn" bindtap="handleSendCode">
          {{countdown > 0 ? countdown + 's' : '获取验证码'}}
        </view>
      </view>
    </view>

    <view class="submit-btn" bindtap="handleBind">
      {{mode === 'change' ? '确认更换' : '确认绑定'}}
    </view>
  </view>
</view>