/* pages/sports/index.wxss */
page{
    background-color: #fff;
    box-sizing: border-box;
    padding: 30rpx;
}
.tab{
    background-color: #F5F5F5;
    display: flex;
    border-radius: 40rpx;
    box-sizing: border-box;
    padding: 6rpx;
}
.tab-item{
    width: 25%;
    text-align: center;
    font-size: 30rpx;
    color: #333333;
    text-align: center;
    font-weight: 500;
    box-sizing: border-box;
    padding: 10rpx 0;
}
.active{
    background-color: #fff !important;
    border-radius: 40rpx;
    /* color: #007aff; */
}
.sportCount{
    width: 100%;
    background-color: #F5F5F5;
    border-radius: 20rpx;
    margin-top: 20rpx;
}
.sportCount-title{
    display: flex;
    justify-content: space-between;
    box-sizing:border-box;
    padding: 30rpx;
    border-bottom: 1rpx solid #DCE1EA;
    font-size: 36rpx;
    color: #333333;
    font-weight: 500;
}
.sportCount-content{
    display: flex;
    flex-wrap: wrap;
}
.sportCount-content-item{
    width: 50%;
    box-sizing:border-box;
    padding: 15rpx 30rpx;
}
.sc-title{
    font-size: 30rpx;
    color: #333333;
    font-weight: 400;   
}
.sc-value{
    margin-top: 10rpx;
    font-size: 50rpx;
    color: #333333;
    font-weight: 700;
}
.sc-value text{
    font-size: 24rpx;
    color: #333333;
    font-weight: 400; 
    margin-left: 10rpx;
}
.dateBox{
    margin-top: 35rpx;
}
.dateBox-value{
    opacity: 0.85 !important;
    font-family: 'PingFangSC-Semibold';
    font-size: 28rpx;
    color: #000000 !important;
    font-weight: 600;   
}
.scroll-view_H{
    white-space: nowrap;
}
.dateBox-value2{
    display: flex;   
    opacity: 0.35;
    font-family: 'PingFangSC-Medium';
    font-size: 28rpx;
    color: #000000;
    font-weight: 500;
}
.month-item{
    margin-right: 30rpx;
    display: inline-block;
    opacity: 0.35;
    font-family: 'PingFangSC-Medium';
    font-size: 28rpx;
    color: #000000;
    font-weight: 500;
    /* width: 100%; */
    /* height: 300rpx; */
}

.sport-stat{
    width: 100%;
    background-color: #F5F5F5;
    border-radius: 20rpx;
    margin-top: 48rpx;
    box-sizing: border-box;
    padding: 36rpx 30rpx;
}
.sport-stat-title{
    display: flex;
    align-items: center;
}
.sport-stat-title image{
    width: 67rpx;
    height: 67rpx;
}
.sport-stat-title view{
    font-family: 'PingFangSC-Semibold';
    font-size: 30rpx;
    color: #333333;
    font-weight: 600;
    margin-left: 19rpx;
}
.sport-stat-content{
    margin-top: 40rpx;
}
.sport-stat-content-item{
    width: 100%;
    display: flex;
    opacity: 0.45;
    font-family: 'PingFangSC-Medium';
    font-size: 24rpx;
    color: #000000;
    font-weight: 500;
}
.sport-stat-content-item-1{
    width: 20%;
}
.sport-stat-content-item-2{
    width: 60%;
}
.sport-stat-content-item-3{
    width: 20%;
    text-align: right;
}
.sport-stat-content-item2{
    display: flex;
    opacity: 0.85;
    font-family: 'PingFangSC-Medium';
    font-size: 28rpx;
    color: #000000;
    font-weight: 500;
    box-sizing: border-box;
    padding: 10rpx 0;
}
.progress{
    background: #D1ECDA;
    border-radius: 20rpx;
    width: 100%;
    height: 40rpx;
    position: relative;
}
.progress-cover{
    position: absolute;
    top: 0;
    left: 0;
    height: 40rpx;
    background: #38D26D;
    border-radius: 20rpx;
    z-index: 10;
}
.progress-text{
    font-family: 'PingFangSC-Medium';
    z-index: 11;
    position: absolute;
    top: 2rpx;
    left: 20rpx;
    font-size: 24rpx;
    color: #FFFFFF;
    font-weight: 500;   
}