/* pages/user/bind/detail.wxss */
page{
    background: #F6F6F6;
}
.title{
    box-sizing: border-box;
    padding: 40rpx 28rpx 20rpx;
    font-size: 30rpx;
    color: #333333;
    letter-spacing: 0.48rpx;
    font-weight: 500;
}

.footer{
    left: 0;
    bottom: 0;
    width: 100%;
    height: 134rpx;
    position: fixed;
    background: #FFFFFF;
    box-shadow: 0px -2rpx 12rpx 0px rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
}
.footer .mvbutton{
    width: 684rpx;
    height: 100rpx;
    line-height: 100rpx;
    background: #00C7C7;
    border-radius: 50rpx;
    font-size: 36rpx;
    color: #FFFFFF;
    text-align: center;
}

.content{
    box-sizing: border-box;
    padding: 50rpx 30rpx;
    flex-direction: column;
    display: flex;
    /* align-items: center; */
    justify-content: space-between;
    height: 100%;
}

.btnBox{
    /* display: flex;
    justify-content: center; */
    width: 100% !important;
    text-align: center;
    margin-top: 20rpx;
}