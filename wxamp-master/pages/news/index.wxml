<view wx:if="{{fromCamp}}" class="camp-news-head">
  <view class="camp-news-head-top">
    <view class="camp-news-title">推荐阅读</view>
    <view class="camp-news-back" bindtap="goCampDetail">返回活动</view>
  </view>
  <view class="camp-news-desc">{{camp_name || '当前活动推荐资讯'}}</view>
</view>

<view class="list">
    <view class="item" wx:for="{{newlist}}" wx:key="nid" bindtap="go_news_detail" data-id="{{item.nid}}">
        <view>
            <view>{{item.title}}</view>
            <view>{{item.create_time}}</view>
        </view>
        <view>
            <image src="{{item.coverimg}}" mode="aspectFill" />
        </view>
    </view>

    <van-empty wx:if="{{newlist.length == 0}}" description="暂无资讯" />
</view>