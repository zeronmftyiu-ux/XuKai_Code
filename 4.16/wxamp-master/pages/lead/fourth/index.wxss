/* pages/lead/fourth/index.wxss */
.header{
    box-sizing: border-box;
    padding: 52rpx 45rpx;
    font-size: 30rpx;
    color: #8F9AA7;
}
.header>view:first-child{
    font-size: 36rpx;
    color: #494C4E;
    font-weight: 500;
    padding-bottom: 12rpx;
}
.van-radio-group{
    box-sizing: border-box;
    padding: 0 62rpx;
    width: 100%;
    margin-bottom: 460rpx;
}
.checkbox{
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1rpx solid rgba(179,185,197,1);
    border-radius: 11rpx;
    box-sizing: border-box;
    padding: 31rpx 34rpx;
    margin-bottom: 36rpx;
    font-size: 32rpx;
    color: #494C4E;
    font-weight: 500;
}

.mvbutton{
    background: #00C7C7;
    border-radius: 60rpx;
    width: 658rpx;
    height: 100rpx;
    text-align: center;
    line-height: 100rpx;
    font-size: 32rpx;
    color: #FFFFFF;
    margin: auto;
}