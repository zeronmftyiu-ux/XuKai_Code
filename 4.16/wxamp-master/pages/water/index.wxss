/* pages/food/index.wxss */
page {
    box-sizing: border-box;
    padding-bottom: 80rpx;
    background: #F8F9FA;
}

.calendar {
    background: url('https://moveclub-file.oss-cn-hangzhou.aliyuncs.com/movewell/img/bg1_water.png') no-repeat;
    background-size: 100% 100%;
    width: 750rpx;
    height: 1341rpx;
    box-sizing: border-box;
    padding-top: 330rpx;
    position: relative;
}

.calendar .left{
    position: absolute;
    left: 20rpx;
    top: 100rpx;
    width: 100rpx;
}
.calendarMain {
    /* width: 100%; */
    text-align: center;
}

.calendar .date{
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-sizing: border-box; 
    width: 690rpx;
    margin: auto;
}

.calendar .date .box{
    width: 40rpx;
    height: 150rpx;
    display: flex;
    align-items: center;
    justify-content: center;
}

.week {
    display: flex;
    justify-content: center;
}

.week-item {
    width: 67rpx;
    height: 67rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'PingFangSC-Regular';
    font-size: 28rpx;
    color: #656565;
    text-align: center;
    font-weight: 400;
    margin: 0 10rpx;
}

.day {
    display: flex;
    justify-content: center;
    margin-top: 10rpx;
}

.day-item {
    width: 67rpx;
    height: 67rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #E8F2FC;
    font-family: 'PingFangSC-Medium';
    font-size: 28rpx;
    color: #000000;
    text-align: center;
    font-weight: 500;
    border-radius: 50%;
    margin: 0 10rpx;
}

.active {
    color: #fff !important;
    background: #42B5FE !important;
}

.textBox {
    display: flex;
    box-sizing: border-box;
    width: 702rpx;
    margin: auto;
    margin-top: 50rpx;
}

.textBox-item {
    display: flex;
    width: 50%;
    align-items: center;
    box-sizing: border-box;
    padding-left: 30rpx;
}

.textBox-item image {
    width: 54rpx;
    height: 54rpx;
}

.textBox-item view {
    opacity: 0.65;
    font-family: 'PingFangSC-Regular';
    font-size: 24rpx;
    color: #000000;
    font-weight: 400;
    margin-left: 10rpx;
}

.list {
    background: #FFFFFF;
    box-shadow: 0px 2rpx 14rpx 0px rgba(0, 0, 0, 0.06);
    border-radius: 12rpx;
    width: 702rpx;
    margin: auto;
}

.item-title {
    display: flex;
    align-items: center;
}

.item-title-01 {
    width: 54rpx;
    height: 54rpx;
}

.item-title-02 {
    font-family: 'PingFangSC-Semibold';
    font-size: 26rpx;
    color: #000000;
    font-weight: 600;
    margin: 0 17rpx;
}

.item-title-03 {
    opacity: 0.45;
    font-family: 'PingFangSC-Regular';
    font-size: 26rpx;
    color: #000000;
    font-weight: 400;
}

.item {
    box-sizing: border-box;
    padding: 36rpx;
}

.foodList-item {
    margin-top: 30rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.left {
    display: flex;
    align-items: center;
    width: 80%;
}

.left-img {
    width: 90rpx;
    height: 90rpx;
    border-radius: 10rpx;
}

.left-text view:nth-child(1) {
    font-family: 'PingFangSC-Semibold';
    font-size: 26rpx;
    color: #000000;
    font-weight: 600;
    width: 100%;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
}

.left-text view:nth-child(2) {
    opacity: 0.45;
    font-family: 'PingFangSC-Regular';
    font-size: 26rpx;
    color: #000000;
    font-weight: 400;
    margin-top: 10rpx;
}

.right {
    opacity: 0.45;
    font-family: 'PingFangSC-Regular';
    font-size: 26rpx;
    color: #000000;
    text-align: right;
    font-weight: 400;
    width: 20%;
}

.left-text {
    margin-left: 20rpx;
    width: calc(100% - 110rpx);
}

.imgbox {
    width: 108rpx;
    height: 112rpx;
    position: fixed;
    right: 67rpx;
    bottom: 111rpx;
}

.editBox{
    height: 100%;
    display: flex;
    flex-direction: column;
}

.editBox .editBox-title {
    text-align: center;
    font-family: 'PingFangSC-Medium';
    font-size: 36rpx;
    color: #333333;
    letter-spacing: 0.58rpx;
    text-align: center;
    font-weight: 500;
    box-sizing: border-box;
    padding: 25rpx 0;
    border-bottom: 1rpx solid #eee;
}

.editBox .formBox {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.editBox .formBox-item2 {
    box-sizing: border-box;
    padding: 30rpx;
}
.editBox .formBox-item2 .van-cell {
    padding: 0rpx;
}
.editBox .formBox-item2 input{
    height: 105rpx;
    border: 2.5rpx solid rgba(236,236,236,1);
    border-radius: 15rpx;
    padding-left: 36rpx;
}

.editBox .form-label {
    font-size: 30rpx;
    color: #000000;
    letter-spacing: -0.94rpx;
    font-weight: 400;
    padding-bottom: 43rpx;
}
.editBox .form-con2 {
    opacity: 0.45;
    font-size: 24rpx;
    color: #333333;
    letter-spacing: 0.39rpx;
    padding-top: 23rpx;
}

.btnBox {
    text-align: center;
    margin-top: 24rpx;
}

.btnBox-1 {
    background: #00C7C7 !important;
    border-radius: 10px !important;
    font-family: 'PingFangSC-Regular';
    font-size: 36rpx !important;
    color: #FFFFFF !important;
    text-align: center !important;
    font-weight: 400 !important;
    width: 683rpx !important;
    height: 100rpx !important;
}

.van-dropdown-menu {
    box-shadow: none !important;
}

.waterBox1 {
    font-family: 'PingFangSC-Regular';
    font-size: 24rpx;
    color: #000000;
    text-align: center;
    font-weight: 400;
    margin-top: 40rpx;
}

.waterBox1 text {
    font-family: 'DINCond-Bold';
    font-size: 97rpx;
    color: #000000;
    text-align: center;
    font-weight: 400;
    margin-right: 10rpx;
}

.waterBox2 {
    opacity: 0.65;
    font-family: 'PingFangSC-Regular';
    font-size: 24rpx;
    color: #001941;
    text-align: center;
    font-weight: 400;
}

.rightBox {
    position: absolute;
    right: 38rpx;
    top: 700rpx;
}

.iconBox {
    width: 138rpx;
    height: 138rpx;
}

.iconBox image {
    width: 138rpx;
    height: 138rpx;
}

.waterMain {
    text-align: center;
    margin-top: 30rpx;
}

.gai {
    width: 318rpx;
    height: 110rpx;
    margin: auto;
    position: relative;
    z-index: 20;
}

.gai image {
    width: 318rpx;
    height: 110rpx;
}

.bei {
    width: 284rpx;
    height: 358rpx;
    margin: auto;
    position: relative;
    z-index: 10;
    margin-top: -20rpx;
}

.bei image {
    width: 284rpx;
    height: 358rpx;
}
.waterValue{
    position: absolute;
    /* opacity: 0.3; */
    background:  #42B5FE;
    border-radius: 0px 0px 24rpx 24rpx;   
    width: 284rpx;
    /* height: 120rpx; */
    left: 0;
    bottom: 0;
    z-index: 20;
}
.progressBox{
    position: absolute;
    z-index: 15;
    background-image: linear-gradient(0deg, rgba(255,255,255,0.00) 0%, #FFFFFF 100%);
    width: 13.25rpx;
    height: 159rpx;
    left: 45.7rpx;
    top: 82.8rpx;
}
.tips{
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 70rpx;
}
.tips image{
    width: 51rpx;
    height: 51rpx;
}
.tips view{
    font-family: 'PingFangSC-Regular';
    font-size: 24rpx;
    color: #001941;
    line-height: 33rpx;
    font-weight: 400;   
    margin-left: 7rpx;
}
.tips view text{
    font-family: 'PingFangSC-Regular';
    font-size: 24rpx;
    color: #42B5FE;
    line-height: 33rpx;
    font-weight: 400;
    text-decoration: underline;
}

.record{
    display: flex;
    justify-content: space-between;
    width: 708rpx;
    margin: auto;
    margin-top: 30rpx;
}
.record-item{
    position: relative;
    background: #FFFFFF;
    box-shadow: 0px 2rpx 12rpx 0px rgba(225,225,225,0.36);
    border-radius: 20rpx;
    width: 342rpx;
    height: 180rpx;
    box-sizing: border-box;
    padding-top: 36rpx;
    padding-left: 30rpx;
}
.record-item image{
    width: 96rpx;
    height: 96rpx;
    position: absolute;
    right: 27rpx;
    bottom: 23rpx;
}
.record-item-01{
    font-family: 'PingFangSC-Regular';
    font-size: 24rpx;
    color: #000000;
    font-weight: 400;
}
.record-item-02{
    font-family: 'PingFangSC-Regular';
    font-size: 24rpx;
    color: #000000;
    font-weight: 400;
}
.record-item-02 text{
    font-family: 'DINCond-Bold';
    font-size: 50rpx;
    color: #000000;
    text-align: center;
    font-weight: 400;
    margin-right: 10rpx;
}