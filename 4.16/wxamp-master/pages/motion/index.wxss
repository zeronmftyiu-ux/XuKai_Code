page {
  background: #F4F6F9 url(https://oss.mcloud.moveclub.cn/2025/csyyls/%E8%BF%90%E5%8A%A8-bg%402x.png) no-repeat;
  width: 100%;
  height: 100%;
  background-position: center top;
  background-size: contain;
  box-sizing: border-box;
  padding-bottom: 80rpx;
}

.header {
  width: 100%;
  height: 88rpx;
  position: relative;
  box-sizing: border-box;
  padding: 128rpx 22rpx 39rpx;
  font-size: 34rpx;
  color: #30292C;
  line-height: 44rpx;
}

.header > view {
  display: flex;
  align-items: center;
}

.main {
  box-sizing: border-box;
  padding: 54rpx 24rpx 180rpx;
}

.main .box {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-sizing: border-box;
  padding: 32rpx;
  margin-bottom: 28rpx;
}

.overview-box {
  box-shadow: 0 8rpx 24rpx rgba(19, 109, 109, 0.06);
}

.detail-box {
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.04);
}

.month-switch {
  display: flex;
  justify-content: center;
  align-items: center;
  padding-bottom: 28rpx;
}

.month-switch .title {
  text-align: center;
  font-size: 30rpx;
  color: #000000;
  font-weight: 600;
  padding: 0 30rpx;
}

.calendar {
  background: #F4FBFB;
  border-radius: 18rpx;
  box-sizing: border-box;
  padding: 18rpx 12rpx;
}

.calendar .weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  font-size: 24rpx;
  color: #B8BDC7;
  padding-bottom: 16rpx;
}

.calendar .days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
}

.day-item {
  height: 92rpx;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: transparent;
  position: relative;
}

.day-num {
  font-size: 34rpx;
  color: #2F333A;
  font-weight: 700;
  line-height: 1;
}

.day-item.has-record {
  background: #EAF8F7;
}

.day-item.today {
  border: 2rpx solid rgba(17, 197, 201, 0.35);
}

.day-item.checked {
  background: linear-gradient(135deg, #11C5C9, #17D7B6);
  box-shadow: 0 8rpx 18rpx rgba(0, 199, 199, 0.22);
}

.day-item.checked .day-num {
  color: #FFFFFF;
}

.day-item.future {
  opacity: 0.42;
}

.day-item.future .day-num {
  color: #B8BDC7;
}

.today-tag {
  margin-top: 6rpx;
  font-size: 18rpx;
  color: #10B8B8;
  line-height: 1;
}

.day-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #10C7C7;
  margin-top: 8rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin-top: 28rpx;
}

.summary-card {
  background: #F8FAFC;
  border-radius: 20rpx;
  padding: 22rpx 18rpx;
  min-height: 132rpx;
  box-sizing: border-box;
}

.summary-label {
  font-size: 22rpx;
  line-height: 32rpx;
  color: #8E97A6;
  min-height: 64rpx;
}

.summary-value {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #2F333A;
  font-weight: 500;
}

.summary-value text {
  font-size: 40rpx;
  color: #0FC6C6;
  font-weight: 700;
  margin-right: 6rpx;
}

.tt {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 26rpx;
}

.tbtn {
  min-width: 280rpx;
  height: 76rpx;
  text-align: center;
  line-height: 76rpx;
  background: linear-gradient(135deg, #11C5C9, #17D7B6);
  border-radius: 38rpx;
  font-size: 34rpx;
  color: #FFFFFF;
  font-weight: 600;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.selected-date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.selected-date {
  font-size: 30rpx;
  color: #1F2430;
  font-weight: 700;
}

.selected-date-tip {
  font-size: 22rpx;
  color: #98A2B3;
}

.healbtn {
  background: #FDF7E0;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 18rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #FF7E00;
  margin-bottom: 28rpx;
}

.healbtn .btn {
  width: 162rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  background: #FFFFFF;
  border: 2rpx solid rgba(255,126,0,1);
  border-radius: 25rpx;
  font-size: 28rpx;
  color: #FF7E00;
  font-weight: 400;
}

.day-list {
  padding-bottom: 12rpx;
}

.day-list .item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 20rpx;
  background: #FAFBFC;
  border-radius: 20rpx;
  margin-bottom: 18rpx;
}

.day-list .item:last-child {
  margin-bottom: 0;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.item-icon-wrap {
  width: 90rpx;
  height: 90rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 14rpx rgba(17, 24, 39, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-left image {
  width: 72rpx;
  height: 72rpx;
  border-radius: 14rpx;
}

.item-left .ct {
  min-width: 0;
}

.item-title {
  font-size: 30rpx;
  color: #111827;
  font-weight: 600;
  line-height: 42rpx;
}

.item-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #98A2B3;
  line-height: 34rpx;
}

.item-right {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.item-cal {
  font-size: 26rpx;
  color: #8E97A6;
  margin-right: 10rpx;
}

.empty-day {
  padding: 52rpx 0 34rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.38;
}

.empty-title {
  margin-top: 20rpx;
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #98A2B3;
  line-height: 36rpx;
}

.add {
  position: fixed;
  right: 28rpx;
  bottom: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 24rpx;
  background: #FFFFFF;
  color: #363A3C;
  text-align: center;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  border-radius: 22rpx;
  box-sizing: border-box;
  padding: 12rpx 12rpx 10rpx;
  z-index: 99;
}

.add image {
  width: 82rpx;
  height: 82rpx;
}

.camp-motion-head {
  margin: 20rpx 24rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.camp-motion-head-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.camp-motion-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222222;
}

.camp-motion-back {
  font-size: 24rpx;
  color: #00c7c7;
}

.camp-motion-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #666666;
}

.camp-motion-point {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #11a675;
}