/* pages/sports/sleep.wxss */
page{
    background-color: #fff;
    box-sizing: border-box;
    padding: 30rpx 30rpx 50rpx 30rpx;
}
.tab{
    background-color: #F5F5F5;
    display: flex;
    border-radius: 40rpx;
    box-sizing: border-box;
    padding: 6rpx;
}
.tab-item{
    /* width: 25%; */
    width: 33.33%;
    text-align: center;
    font-size: 32rpx;
    color: #333333;
    text-align: center;
    font-weight: 500;
    box-sizing: border-box;
    padding: 10rpx 0;
}
.active{
    background-color: #fff !important;
    border-radius: 40rpx;
    /* color: #007aff; */
}
.dateBox{
    margin-top: 35rpx;
}
.dateBox-value{
    opacity: 0.85 !important;
    font-family: 'PingFangSC-Semibold';
    font-size: 28rpx;
    color: #000000 !important;
    font-weight: 600;   
}
.dateBox-value image{
    width: 27rpx;
    height: 18rpx;
    margin-left: 5rpx;
}
.scroll-view_H{
    white-space: nowrap;
}
.dateBox-value2{
    display: flex;   
    opacity: 0.35;
    font-family: 'PingFangSC-Medium';
    font-size: 28rpx;
    color: #000000;
    font-weight: 500;
}
.month-item{
    margin-right: 30rpx;
    display: inline-block;
    opacity: 0.35;
    font-family: 'PingFangSC-Medium';
    font-size: 28rpx;
    color: #000000;
    font-weight: 500;
    /* width: 100%; */
    /* height: 300rpx; */
}

.labelBox{
    display: flex;
    justify-content: space-between;
    margin: 16rpx 20rpx 10rpx;
}
.labelBox-item{
    /* width: 25%; */
    display: flex;
    align-items: center;
}
.text01{
    font-family: 'PingFangSC-Regular';
    font-size: 26rpx;
    color: #000000;
    font-weight: 400;   
}
.square{
    border-radius: 4rpx;
    width: 18rpx;
    height: 18rpx;
    margin-right: 10rpx;
}
.text02{
    opacity: 0.65;
    font-family: 'PingFangSC-Regular';
    font-size: 24rpx;
    color: #000000;
    letter-spacing: -1rpx;
    line-height: 40rpx;
    font-weight: 400;    
    margin-top: 40rpx;
}
.color1{
    background: #8781EC;
}
.color2{
    background: #88CEFA;
}
.color3{
    background: #F7B500;
}
.color4{
    background: #01DE6C;
}
.sport-stat{
    width: 100%;
    background-color: #F5F5F5;
    border-radius: 20rpx;
    margin-top: 48rpx;
    box-sizing: border-box;
    padding: 36rpx 30rpx;
}
.sport-stat-title{
    display: flex;
    align-items: center;
}
.sport-stat-title image{
    width: 67rpx;
    height: 67rpx;
}
.sport-stat-title .title01{
    font-family: 'PingFangSC-Semibold';
    font-size: 32rpx;
    color: #333333;
    font-weight: 600;
    margin-left: 19rpx;
}
.sport-stat-content{
    margin-top: 40rpx;
    display: flex;
}
.title02{
    font-family: 'PingFangSC-Regular';
    font-size: 24rpx;
    color: #333333;
    font-weight: 400;
    margin-left: 20rpx;
}
.title02 text{
    font-family: 'DINPro-Bold';
    font-size: 44rpx;
    color: #333333;
    font-weight: 700;  
    margin: 0 10rpx; 
}
.sport-stat-content-label{
    margin-left: 50rpx;
    width: calc(100% - 240rpx);
}
.label-item{
    display: flex;
    align-items: center;
    font-family: 'PingFangSC-Regular';
    font-size: 26rpx;
    color: #000000;
    font-weight: 400;
    justify-content: space-between;
    margin: 20rpx 0;
}
.left{
    display: flex;
    align-items: center;
}