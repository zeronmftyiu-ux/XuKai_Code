<!--pages/sports/heart.wxml-->
<view class="main">
    <view class="tab">
        <block wx:for="{{ tab }}">
            <view class="tab-item {{ idx == index ? 'active' : '' }}" data-idx="{{ index }}" bindtap="toggleTab">{{ item }}</view>
        </block>       
    </view>
    <!-- 日 -->
    <!-- <view class="dateBox" wx:if="{{ idx == 0 }}">
        <view class="dateBox-value" bindtap="showDate">
            {{ dayValue }}
            <image src="https://moveclub-file.oss-cn-hangzhou.aliyuncs.com/movewell/assets/%E4%B8%89%E8%A7%92%E5%BD%A2%402x.png"></image>
        </view>
    </view> -->
   <!-- 周 -->
   <view class="dateBox" wx:if="{{ tab[idx] == '周' }}">
        <view class="dateBox-value" bindtap="showDate">
            {{ weekValue }}
            <image src="https://moveclub-file.oss-cn-hangzhou.aliyuncs.com/movewell/assets/%E4%B8%89%E8%A7%92%E5%BD%A2%402x.png"></image>
        </view>
    </view>
    <!-- 月 -->
    <view class="dateBox" wx:if="{{ tab[idx] == '月' }}">
        <scroll-view class="scroll-view_H" scroll-x="true" bindscroll="scroll" style="width: 100%">
            <view class="month-item {{ month_idx == index ? 'dateBox-value' : '' }}" wx:for="{{ months }}" data-idx="{{ index }}" bindtap="toggleMonth">{{ item.month }}</view>
        </scroll-view>
    </view>

    <view class="echarts">
        <chart chart-class="chart" width="690rpx" height="450rpx" option="{{ option }}" bindinstance="onInstance" />
    </view>

    <view class="sport-stat">
        <view class="sport-stat-title">
            <image src="https://moveclub-file.oss-cn-hangzhou.aliyuncs.com/movewell/assets/%E5%BF%83%E7%8E%87%402x.png"></image>
            <view class="title01">心率概览</view>
        </view>
        <view class="sport-stat-content">
            <view class="sport-stat-content-item">
                <view class="text01"><text>{{ maxvalue }}</text>次/分</view>
                <view class="text02">最高心率</view>
            </view>
            <view class="sport-stat-content-item">
                <view class="text01"><text>{{ minvalue  }}</text>次/分</view>
                <view class="text02">最低心率</view>
            </view>
            <view class="sport-stat-content-item">
                <view class="text01"><text>{{ lastvalue  }}</text>次/分</view>
                <view class="text02">最近心率</view>
            </view>
            <view class="sport-stat-content-item">
                <view class="text01"><text>{{ avgvalue  }}</text>次/分</view>
                <view class="text02">平均心率</view>
            </view>
            
        </view>
    </view>

</view>

<van-calendar show="{{ show }}" min-date="{{ minDate }}" bind:close="onClose" bind:select="selectDate" show-confirm="{{ false }}" />