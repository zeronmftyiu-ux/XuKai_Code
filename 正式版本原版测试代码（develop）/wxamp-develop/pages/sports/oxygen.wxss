/* pages/sports/heart.wxss */
page{
    background-color: #fff;
    box-sizing: border-box;
    padding: 30rpx 30rpx 50rpx 30rpx;
}
.tab{
    background-color: #F5F5F5;
    display: flex;
    border-radius: 40rpx;
    box-sizing: border-box;
    padding: 6rpx;
}
.tab-item{
    width: 33.33%;
    /* width: 25%; */
    text-align: center;
    font-size: 30rpx;
    color: #333333;
    text-align: center;
    font-weight: 500;
    box-sizing: border-box;
    padding: 10rpx 0;
}
.active{
    background-color: #fff !important;
    border-radius: 40rpx;
    /* color: #007aff; */
}
.dateBox{
    margin-top: 35rpx;
}
.dateBox-value{
    opacity: 0.85 !important;
    font-family: 'PingFangSC-Semibold';
    font-size: 28rpx;
    color: #000000 !important;
    font-weight: 600;   
}
.dateBox-value image{
    width: 27rpx;
    height: 18rpx;
    margin-left: 5rpx;
}
.scroll-view_H{
    white-space: nowrap;
}
.dateBox-value2{
    display: flex;   
    opacity: 0.35;
    font-family: 'PingFangSC-Medium';
    font-size: 28rpx;
    color: #000000;
    font-weight: 500;
}
.month-item{
    margin-right: 30rpx;
    display: inline-block;
    opacity: 0.35;
    font-family: 'PingFangSC-Medium';
    font-size: 28rpx;
    color: #000000;
    font-weight: 500;
    /* width: 100%; */
    /* height: 300rpx; */
}

.sport-stat{
    width: 100%;
    background-color: #F5F5F5;
    border-radius: 20rpx;
    margin-top: 48rpx;
    box-sizing: border-box;
    padding: 36rpx 30rpx;
}
.sport-stat-title{
    display: flex;
    align-items: center;
}
.sport-stat-title image{
    width: 67rpx;
    height: 67rpx;
}
.sport-stat-title .title01{
    font-family: 'PingFangSC-Semibold';
    font-size: 30rpx;
    color: #333333;
    font-weight: 600;
    margin-left: 19rpx;
}
.sport-stat-content{
    margin-top: 40rpx;
    display: flex;
    flex-wrap: wrap;
}
.sport-stat-content-item{
    width: 50%;
    margin-bottom: 20rpx;
}
.text01{
    font-family: 'PingFangSC-Regular';
    font-size: 24rpx;
    color: #333333;
    font-weight: 400;
}
.text01 text{
    font-family: 'DINPro-Bold';
    font-size: 50rpx;
    color: #333333;
    font-weight: 700; 
    margin-right: 10rpx;  
}
.text02{
    opacity: 0.45;
    font-family: 'PingFangSC-Regular';
    font-size: 28rpx;
    color: #000000;
    font-weight: 400;
    margin-top: 5rpx;
}
.abnormalList{
    margin-top: 48rpx;
}
.abnormalList-title{
    font-family: 'PingFangSC-Regular';
    font-size: 32rpx;
    color: #000000;
    font-weight: 400;   
}
.item{
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #FFFFFF;
    border-radius: 8rpx; 
    box-sizing: border-box;
    padding: 18rpx 24rpx;
    margin-top: 16rpx;
}
.item-left{
    font-family: 'PingFangSC-Semibold';
    font-size: 32rpx;
    color: #000000;
    font-weight: 600;
}
.item-left text:nth-child(1){
    color: #F58A32;
    margin-left: 5rpx;
}
.item-left text:nth-child(2){
    font-family: 'PingFangSC-Regular';
    font-size: 24rpx;
    color: #333333;
    font-weight: 400;
}
.item-right{
    opacity: 0.45;
    font-family: 'PingFangSC-Regular';
    font-size: 28rpx;
    color: #000000;
    text-align: right;
    font-weight: 400;
}
.labelBox{
    display: flex;
    justify-content: space-between;
    margin-top: 10rpx;
}
.labelBox-item{
    /* width: 25%; */
    display: flex;
    align-items: center;
}
.text01{
    font-family: 'PingFangSC-Regular';
    font-size: 26rpx;
    color: #000000;
    font-weight: 400;   
}
.square{
    border-radius: 4rpx;
    width: 18rpx;
    height: 18rpx;
    margin-right: 10rpx;
}
.text02{
    opacity: 0.65;
    font-family: 'PingFangSC-Regular';
    font-size: 24rpx;
    color: #000000;
    letter-spacing: -1rpx;
    /* line-height: 40rpx; */
    font-weight: 400;    
    margin-top: 20rpx;
}
.color1{
    background: #88CEFA;
}
.color2{
    background: #01DE6C;
}
.color3{
    background: #F7B500;
}
.color4{
    background: #F58A32;
}
.progressBox{
    display: flex;
    width: 100%;
    margin-top: 40rpx;
}
.progressBox-item{
    height: 38rpx;
    width: 25%;
}
.progressBox-item:first-child{
    border-radius: 100rpx 0px 0px 100rpx;
}
.progressBox-item:last-child{
    border-radius:  0px 100rpx 100rpx 0px ;
}
.border1{
    border-radius: 100rpx 0px 0px 100rpx;
}
.border2{
    border-radius:  0px 100rpx 100rpx 0px ;
}
.border3{
    border-radius: 100rpx;
}

.progressBox2{
    margin-top: 40rpx;
}
.progressBox2-item{
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 15rpx 0;
}
.time{
    font-family: 'PingFangSC-Regular';
    font-size: 26rpx;
    color: #000000;
    text-align: right;
    font-weight: 400;   
}
