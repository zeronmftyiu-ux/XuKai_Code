page {
  background-color: #F4F6F9;
  box-sizing: border-box;
  padding: 24rpx;
}

.main {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.chart-card,
.bmi-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  box-sizing: border-box;
  padding: 28rpx 24rpx;
}

.chart-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.chart-title,
.sport-stat-title {
  font-size: 34rpx;
  color: #262B2D;
  font-weight: 600;
}

.period-tabs {
  display: flex;
  align-items: center;
  padding: 4rpx;
  background: #F2F4F7;
  border-radius: 999rpx;
}

.period-tab {
  min-width: 84rpx;
  height: 48rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  color: #6F788B;
  font-size: 24rpx;
  line-height: 48rpx;
  text-align: center;
  box-sizing: border-box;
}

.period-tab-active {
  background: #11C5C9;
  color: #FFFFFF;
  font-weight: 600;
}

.chart-summary {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.chart-summary-label {
  font-size: 24rpx;
  color: #8B9299;
  line-height: 34rpx;
}

.chart-summary-value {
  margin-top: 6rpx;
  font-size: 52rpx;
  line-height: 1.1;
  color: #262626;
  font-weight: 700;
}

.chart-summary-value text {
  font-size: 24rpx;
  font-weight: 400;
  margin-left: 8rpx;
  color: #6F788B;
}

.chart-summary-desc {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  background: rgba(17, 197, 201, 0.10);
  color: #11C5C9;
}

.chart-wrap {
  position: relative;
  width: 654rpx;
  height: 420rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: visible;
}

.trend-canvas {
  width: 654rpx;
  height: 420rpx;
  display: block;
  position: relative;
  z-index: 1;
}

.point-tooltip {
  position: absolute;
  z-index: 20;
  min-width: 180rpx;
  max-width: 240rpx;
  padding: 16rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(38, 43, 45, 0.12);
  box-sizing: border-box;
  transform: translateX(-50%);
}

.point-tooltip-weight {
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #11C5C9;
}

.point-tooltip-date {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 32rpx;
  color: #2F3A4A;
}

.sport-stat-content {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx 0;
  margin-top: 24rpx;
}

.sport-stat-content-item {
  width: 48%;
  background: #F8FBFC;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  box-sizing: border-box;
}

.sport-stat-content-item-1 {
  font-size: 40rpx;
  color: #262626;
  font-weight: 700;
  line-height: 1.2;
}

.sport-stat-content-item-1 text {
  font-size: 22rpx;
  font-weight: 400;
  margin-left: 6rpx;
}

.sport-stat-content-item-2 {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6F788B;
}

.progress-panel {
  margin-top: 24rpx;
  padding: 22rpx 16rpx 10rpx;
  background: #FFFFFF;
  border-radius: 18rpx;
  border: 1rpx solid #EEF2F6;
}

.bmi-level-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  background: #F2F4F7;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #344054;
  line-height: 1;
  margin-bottom: 20rpx;
}

.progress-main {
  position: relative;
  display: flex;
  width: 100%;
  height: 20rpx;
  border-radius: 20rpx;
  overflow: visible;
}

.progress-main-1,
.progress-main-2,
.progress-main-3,
.progress-main-4 {
  height: 100%;
}

.progress-main-1 {
  width: 170rpx;
  background: #7DB8FF;
  border-radius: 20rpx 0 0 20rpx;
}

.progress-main-2 {
  width: 200rpx;
  background: #5ED39A;
}

.progress-main-3 {
  width: 144rpx;
  background: #FFC34D;
}

.progress-main-4 {
  flex: 1;
  background: #FF8E66;
  border-radius: 0 20rpx 20rpx 0;
}

.bmi-arrow {
  position: absolute;
  top: -18rpx;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 16rpx solid #262626;
  transform: translateX(-50%);
  z-index: 2;
}

.progress-main2 {
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
  padding: 0 10rpx;
  font-size: 22rpx;
  color: #8B9299;
}

.labelBox {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 24rpx;
}

.labelBox-item {
  display: flex;
  align-items: center;
}

.square {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  margin-right: 10rpx;
}

.color1 {
  background: #7DB8FF;
}

.color2 {
  background: #5ED39A;
}

.color3 {
  background: #FFC34D;
}

.color4 {
  background: #FF8E66;
}

.text01 {
  font-size: 24rpx;
  color: #4B5563;
}

.text02 {
  margin-top: 22rpx;
  font-size: 24rpx;
  line-height: 38rpx;
  color: #6F788B;
}