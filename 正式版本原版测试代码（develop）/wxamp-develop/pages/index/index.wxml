<view class="header">
  <view class="info">
    <image src="{{userInfo.avatarurl}}" />
    <view class="name">{{userInfo.nickname}}</view>
    <view class="points" bindtap="gopoint">
      <view >{{totalpoint}} 积分</view>
      <van-icon name="arrow" />
    </view>
  </view>
  <view class="message" bindtap="gomessage">
    <van-icon wx:if="{{userInfo.chatinfo.unreadnum == 0}}" name="https://oss.mcloud.moveclub.cn/2025/mv/mess.png" size="42rpx" />
    <van-icon wx:else name="https://oss.mcloud.moveclub.cn/2025/mv/mess.png" size="42rpx" info="{{userInfo.chatinfo.unreadnum}}" />
    <!-- <image src="https://oss.mcloud.moveclub.cn/2025/mv/mess.png" /> -->
    <view >消息</view>
  </view>
</view>

<view style="margin-bottom: 20rpx;">
