        </view>
        <image src="https://oss.mcloud.moveclub.cn/2025/mv/r.png" />
        <!-- <view wx:if="{{list.length>0}}" class="indicator">
          <view class="dot {{currentIndex === 0 ? 'active' : ''}}"></view>
          <view class="dot {{currentIndex === 1 ? 'active' : ''}}"></view>
        </view> -->
      </view>
    </swiper-item>
    <!-- <swiper-item>
      <view class="advice" bindtap="goadvice">
        <view >
          <image src="https://oss.mcloud.moveclub.cn/2025/mv/zhu.png" />
          <view style="margin-left: 8rpx;">智能生成21天运动计划，去看看</view>
        </view>
        <image src="https://oss.mcloud.moveclub.cn/2025/mv/r.png" />
        <view wx:if="{{list.length>0}}" class="indicator">
          <view class="dot {{currentIndex === 0 ? 'active' : ''}}"></view>
          <view class="dot {{currentIndex === 1 ? 'active' : ''}}"></view>
        </view>
      </view>
    </swiper-item> -->
  </swiper>
  
</view>


<view class="hot">
    <m-banner-list bannerList="{{bannerList}}" indicatorDots="{{false}}" wx:if="{{bannerList.length}}"></m-banner-list>
</view>

<view class="echats">
  <view class="top">
    <view >吃动平衡</view>
    <view wx:if="{{cyclelist.length>0}}" bindtap="gobalance">查看日志 <van-icon name="arrow" /></view>
  </view>
  <block wx:if="{{cyclelist.length>0}}">
    <view class="left">
      <view class="one">
        <view >饮食摄入</view>
        <view >{{balance1||0}}</view>
      </view>
      <view class="canvas">
        <canvas type="2d" id="canvas" class="my-canvas" style="width: 300rpx;height: 200rpx;"></canvas>
        <view class="btn-area">
          <view >还可摄入</view>
          <view >{{balance2||balance4}}</view>
        </view>
      </view>
      <view class="one">
        <view bind:tap="showt">
          <image src="https://oss.mcloud.moveclub.cn/2025/mv/info-circle-fill.png" />
          <view >运动消耗</view>
          
        </view>
        <view >{{balance3||0}}</view>
      </view>
    </view>
    <view class="notice">目标摄入为{{balance4}}千卡</view>
  </block>
  <view wx:else class="cover" bindtap="plan"></view>
</view>
<view class="tabs">
  <view wx:for="{{tags}}" class="tab" wx:key="index" data-url="{{ item.jumpurl }}" bindtap="jumpurl">
    <image src="{{item.icon}}" />
  </view>
</view>
<view class="healths">
  <view class="title">
    <view style="margin-top: 4rpx;">
      <view >体重记录</view>
      <view>{{userInfo.update_time}} 更新</view>
    </view>
    <view style="font-size: 28rpx;display:flex;align-items: center;color: #61656C" bind:tap="gotrend">
      <!-- <image style="width: 40rpx;height: 40rpx;padding:0 8rpx 0 0 " src="http://oss.mcloud.moveclub.cn/2025/mv/doctor/%E8%B6%8B%E5%8A%BF%402x.png" /> -->
      <view>查看趋势 <van-icon name="arrow" /></view>
    </view>
  </view>
  <view class="heal" >
    <view >
      <div style="font-size: 44rpx;margin-right: 8rpx">{{userInfo.weight||'--'}}</div>
      <text >公斤</text> 
    </view>
    <view class="bmi" wx:if="{{userInfo.bmi}}">
      <view >BMI</view>
      <view >{{userInfo.bmi}} <van-tag color="{{info.color}}">{{info.name}}</van-tag></view>
    </view>
    <view class="add" bindtap="toWeight">
      +记录
    </view>
  </view>
  <block wx:if="{{cyclelist.length>0}}">
    <van-progress percentage="{{pro}}" text-color="#02C7C7" pivot-text="已减{{prose}}" pivot-color="#FFFFFF" stroke-width="18rpx" color="#00C7C7" />
    <view class="bi">
      <view >
        初始
        <text >{{cyclelist[0].weight[0].weight}}</text>
      </view>
      <view >
        目标
        <text >{{cyclelist[0].target}}</text>
      </view>
    </view>
  </block>
  <block wx:else>
    <view class="plan">
      <view >
        <image src="https://oss.mcloud.moveclub.cn/2025/mv/plan.png" />
        <text >是否定制您的体重管理计划</text>
      </view>  
      <view class="btn" bindtap="plan">定制计划</view>
    </view>
  </block>
  
</view>

<view class="ai">
  <view class="search" bindtap="toPage">
    <view class="input">有体重问题，先来问问我吧</view>
    <view class="icon">
      <image src="https://oss.mcloud.moveclub.cn/2024/movewell/saerch.png" />
      <text >搜索</text>
    </view>
  </view>
  <view class="setic">
    <view >试试这样问我</view>
    <view >体重管理需要注意哪些？</view>
  </view>
</view>

