<view class="cover">
  <image src="{{current.coverimg}}" mode="widthFix" />
</view>
<view class="head">
  <view class="auth">
    <van-icon name="manager" />
    <view style="margin-left: 18rpx">
      {{current.author}}
    </view>
  </view>
  <view class="title">{{current.title}}</view>
  <view class="info">
    <view class="date">{{current.date}}</view>
    <view class="views">{{current.views}} 浏览</view>
  </view>
</view>

<view class="detail">
    <wxParse nodes="{{ current.newsdetail }}" />
</view>

<view class="foot">
  <view class="btn-area">
