      <button size="mini" plain style="{{current.favorite?'color:#FF5507;':'color:#999'}}">
        {{current.favorite?'已收藏':'收藏'}}
      </button>
    </view> -->
    <view>
      <button open-type="share" size="mini" plain style="display: flex;align-items: center;">
