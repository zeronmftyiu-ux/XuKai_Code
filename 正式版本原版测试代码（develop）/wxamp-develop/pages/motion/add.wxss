page{
    background: #fff;
}

.header{
    box-sizing: border-box;
    padding: 30rpx 0 10rpx;
    background: #fff;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 999;
}
.container {
    display: flex;
    height: calc(100vh - 148rpx);
    margin-top: 148rpx; /* 确保内容不会被头部遮挡 */
}

.container .category-list {
    width: 248rpx;
    background: #F4F6F9;
    box-sizing: border-box;
    padding: 16rpx 0;
}
  
.container .category-item {
    padding: 27rpx 30rpx;
    font-size: 30rpx;
    color: rgb(0, 0, 0, .45);
}
  
.container .category-item.active {
    background-color: #fff;
    font-weight: 600;
    color: rgb(0, 0, 0, .85);
}
.product-list {
    flex: 1;
    box-sizing: border-box;
    padding: 30rpx;
}
  
.product-list .item{
    display: flex;
    align-items: center;
    width: 100%;
    justify-content: space-between;
    margin-bottom: 30rpx;
    padding: 0 15rpx 30rpx 0;
    box-sizing: border-box;
    border-bottom: 0.5rpx solid rgb(235, 237, 240, 1);
}
.product-list .item .left{
    display: flex;
    align-items: center;
}

.product-list .item .left image{
    border-radius: 9rpx;
    width: 80rpx;
    height: 80rpx;
    margin-right: 24rpx;
}

.product-list .item .left .ct{
    font-size: 26rpx;
    color: rgba(0, 0, 0, .45);
}
.product-list .item .left .ct>view:first-child{
    font-size: 26rpx;
    color: #000000;
    font-weight: 600;
}

.product-list .add {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;   
}

.product-list .add image{
    width: 218rpx;
    height: 218rpx;
    margin-bottom: 62rpx;
}
.product-list .add .mvbutton{
    background: #00C7C7;
    box-shadow: inset 0px 0px 16rpx 0px rgba(255,255,255,0.4);
    border-radius: 48rpx;
    width: 472rpx;
    height: 96rpx;
    text-align: center;
    line-height: 96rpx;
    font-size: 34rpx;
    color: #FFFFFF;
}

