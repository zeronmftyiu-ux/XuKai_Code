.footer{
    position: fixed;
    z-index: 99;
    left: 0;
    bottom: 0;
    background: #FFFFFF;
    box-shadow: 0px -2rpx 12rpx 0px rgba(0,0,0,0.1);
    width: 100%;
    height: 132rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-sizing: border-box;
    padding: 0 30rpx;
}
.footer>view:first-child{
    display: flex;
    align-items: center;
}
.footer>view:first-child image{
    width: 100rpx;
    height: 100rpx;
    margin-right: 20rpx;
}

.footer .btn{
    width: 330rpx;
    height: 100rpx;
    text-align: center;
    line-height: 100rpx;
    background: #00C7C7;
    border-radius: 50rpx;
    color: #FFFFFF;
    font-size: 36rpx;
}
.editBox{
    height: 100%;
    display: flex;
    flex-direction: column;
}
.editBox .editBox-title{
    text-align: center;
    font-size: 36rpx;
    color: #333333;
    letter-spacing: 0.58rpx;
    text-align: center;
    font-weight: 500;
    box-sizing: border-box;
    padding: 25rpx 0;
    border-bottom: 1rpx solid #eee;
}

.editBox .formBox{
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.editBox .formBox input{
    height: 105rpx;
    border: 2.5rpx solid rgba(236,236,236,1);
    border-radius: 15rpx;
    padding-left: 36rpx;
    padding-left: 10rpx;
}

.editBox .formBox .formBox-item1{
    display: flex;
    align-items: center;
    border-bottom: 1rpx solid #eee;
    box-sizing: border-box;
    padding: 30rpx;
}

.editBox .formBox .formBox-item1 image{
    border-radius: 9rpx;
    width: 80rpx;
    height: 80rpx;
    margin-right: 24rpx;
}
.editBox .formBox .formBox-item1 .ct{
    font-size: 26rpx;
    color: rgba(0, 0, 0, .45);
}
.editBox .formBox .formBox-item1 .ct>view:first-child{
    font-size: 26rpx;
    color: #000000;
    font-weight: 600;
}

.editBox .formBox .formBox-item2{
    display: flex;
    align-items: center;
    border-bottom: 1rpx solid #eee;
    box-sizing: border-box;
    padding: 30rpx 0;
}

.editBox .formBox .formBox-item2 .formBox-item2-item{
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    font-size: 24rpx;
    color: #333333;
    letter-spacing: 0.39rpx;
    width: 25%;
}
.editBox .formBox .formBox-item2 .formBox-item2-item>view:nth-child(2){
    color: rgb(51, 51, 51, .45);
    padding-top: 8rpx;
}

.editBox .formBox .formBox-item3{
    box-sizing: border-box;
    padding: 30rpx;
    /* display: flex; */
    /* justify-content: flex-end; */
}
.editBox .btnBox{
    text-align: center;
    margin-top: 24rpx;
}
.editBox .btnBox-1{
    background: #00C7C7 !important;
    border-radius: 10px !important;  
    font-family: 'PingFangSC-Regular';
    font-size: 36rpx !important;
    color: #FFFFFF !important;
    text-align: center !important;
    font-weight: 400 !important;  
    width: 683rpx !important;
    height: 100rpx !important;
}

.editList{
    height: 100%;
    overflow-x: hidden;
    overflow-y: auto;
    box-sizing: border-box;
    padding: 90rpx 30rpx 50rpx;
}

.editList .editList-item{
    display: flex;
    align-items: center;
    width: 100%;
    justify-content: space-between;
    margin-bottom: 45rpx;
}
.editList .editList-item .editList-item-left{
    display: flex;
    align-items: center;
}

.editList .editList-item .editList-item-left image{
    border-radius: 9rpx;
    width: 80rpx;
    height: 80rpx;
    margin-right: 24rpx;
}

.editList .editList-item .editList-item-left .ct{
    font-size: 26rpx;
    color: rgba(0, 0, 0, .45);
}
.editList .editList-item .editList-item-left .ct>view:first-child{
    font-size: 26rpx;
    color: #000000;
    font-weight: 600;
}