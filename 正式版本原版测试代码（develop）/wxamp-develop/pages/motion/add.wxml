<van-sticky>
    <view class="header">
        <van-search
            value="{{ value }}"
            shape="round"
            placeholder="请输入运动名称"
            clearable
            bind:search="onSearch"
            bind:change="onSearch"
            bind:cancel="onCancel"
            bind:clear="onCancel"
            />
    </view>
</van-sticky>
<view class="container">
    <scroll-view scroll-y class="category-list" bindscroll="onCategoryScroll">
        <view wx:for="{{tabList}}" wx:key="index" class="category-item {{active === index ? 'active' : ''}}" wx:key="index" data-type="{{index}}" bindtap="change">
        {{item}}
        </view>
    </scroll-view>
    <scroll-view scroll-y class="product-list">
        <view class="item" wx:for="{{list}}" wx:key="index" data-item="{{item}}" bindtap="add">
            <view class="left">
                <image src="{{item.icon}}" />
                <view class="ct">
                    <view >{{item.title}}</view>
                    <view >{{item.value | 0}}千卡/{{item.unitvalue||''}}{{item.unit||''}}</view>
                </view>
            </view>
            <van-icon wx:if="{{item.num && item.num > 0}}" name="add-o" size="45rpx" info="1" />
            <van-icon wx:else name="add-o" size="45rpx" />
            <!-- <view class="add">
                <image class="add"  src="https://oss.mcloud.moveclub.cn/movewell/img/add%402x.png" />
            </view> -->
            
        </view>
        <van-empty wx:if="{{list.length==0}}" description="暂无数据" />
    </scroll-view>
</view>
