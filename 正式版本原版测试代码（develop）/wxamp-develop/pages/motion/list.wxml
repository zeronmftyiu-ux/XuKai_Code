<van-popup show="{{ showS }}" position="bottom" round="{{ true }}" custom-style="height: 55%;" bind:close="onClose"
    closeable="{{ true }}">
    <view class="editBox">
        <view class="editBox-title">编辑运动</view>
        <view class="formBox">
            <view >
                <view class="formBox-item1">
                    <image src="{{item.icon}}" />
                    <view class="ct">
                        <view >{{item.title}}</view>
                        <view >{{item.energy}}千卡/{{item.unitvalue||''}}{{item.unit||''}}</view>
                    </view>
                </view>
                <view class="formBox-item3">
                    <van-field
                        value="{{ item.value }}"
                        center
                        label=""
                        type="digit"
                        placeholder="请输入"
                        border="{{ false }}"
                        use-button-slot
                        bind:input="changenum"
                        bind:change="changenum"
                    >
                        <view slot="button" size="small" type="primary">
                            {{item.unit}}
                        </view>
                    </van-field>
                </view>
            </view>
                
            <view class="btnBox">
                <view class="btnBox-1 cel" bindtap="delFood">删除</view>
                <view class="btnBox-1" bindtap="addFood">确认打卡</view>
            </view>
        </view>
    </view>
</van-popup>

<van-popup show="{{ showT }}" close-on-click-overlay="{{true}}" bind:click-overlay="onClose" bind:close="onClose" custom-style="width: 640rpx;" round>
    <view class="pop">
        <view class="pt">请选择数据同步来源</view>
        <view class="pc">
            <van-radio-group value="{{ radio }}" bind:change="onChange">
                <van-cell title="{{item.title}}" title-class="cell-title" clickable data-name="{{item.id}}" size="large" border="{{ false }}" bind:click="onClick" wx:for="{{sourelist}}" wx:key="idx">
                    <image src="{{item.icon}}" slot="icon" />
                    <van-radio slot="right-icon" style="display:flex" checked-color="#00C7C7" name="{{item.id}}" />
                </van-cell>
                <!-- <van-cell title="微信运动步数" title-class="cell-title" clickable data-name="2" size="large" border="{{ false }}" bind:click="onClick">
                    <image src="https://oss.mcloud.moveclub.cn/2025/csyyls/wchat.png" slot="icon" />
                    <van-radio slot="right-icon" style="display:flex" checked-color="#00C7C7" name="2" />
                </van-cell> -->
            </van-radio-group>
        </view>
        <view class="btn">
            <view bindtap="onClose">取消</view>
            <view bindtap="onConfirmT">确定</view>
        </view>
    </view>
</van-popup>

