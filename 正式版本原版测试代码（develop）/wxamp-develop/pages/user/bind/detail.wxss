/* pages/user/bind/detail.wxss */
page{
    background: #F6F6F6;
}
.title{
    box-sizing: border-box;
    padding: 40rpx 28rpx 20rpx;
    font-size: 30rpx;
    color: #333333;
    letter-spacing: 0.48rpx;
    font-weight: 500;
}

.footer{
    left: 0;
    bottom: 0;
    width: 100%;
    height: 134rpx;
    position: fixed;
    background: #FFFFFF;
    box-shadow: 0px -2rpx 12rpx 0px rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
}
.footer .mvbutton{
    width: 684rpx;
    height: 100rpx;
    line-height: 100rpx;
    background: #00C7C7;
    border-radius: 50rpx;
    font-size: 36rpx;
    color: #FFFFFF;
    text-align: center;
}

.content{
    box-sizing: border-box;
    padding: 50rpx 30rpx;
    flex-direction: column;
    display: flex;
    /* align-items: center; */
    justify-content: space-between;
    height: 100%;
}

.btnBox{
    /* display: flex;
    justify-content: center; */
    width: 100% !important;
    text-align: center;
    margin-top: 20rpx;
}

.van-field__label {
    white-space: nowrap;
}

.weightlist {
    width: 100%;
    box-sizing: border-box;
    padding: 4rpx 28rpx 0rpx;
    background: #FFFFFF;
}
.weightlist .eachlist {
    display: flex;
    justify-content: space-between;
    padding: 24rpx 0;
    border-bottom: 1rpx solid rgba(238,238,238,1);
}
.weightlist .eachlist .left{
    opacity: 0.85;
    font-size: 34rpx;
    color: #000000;
    font-weight: 400;
    white-space: nowrap;
}
.weightlist .eachlist .right{
    opacity: 0.85;
    font-size: 34rpx;
    color: #000000;
    font-weight: 400;
}

.plan {
    background: #FFFFFF;
    padding: 50rpx 40rpx 0rpx;
    margin: 0 0 40rpx 0;
    align-items: center;
    display: flex;
    flex-direction: column;
    height: 350rpx;
}
.plan .jihuaicon{
    width: 139rpx;
    height: 119rpx;
    padding: 30rpx 0 20rpx 0;
}
.plan .text{
    opacity: 0.65;
    font-size: 24rpx;
    color: #000000;
    font-weight: 400;
    padding: 0 0 20rpx 0;
}
.plan .planbutton{
    font-size: 24rpx;
    color: #05B8AD;
    font-weight: 600;
    background: #FFFFFF;
    border: 1rpx solid rgba(5,184,173,1);
    border-radius: 28rpx;
    padding: 10rpx 20rpx;
}