page {
  min-height: 100vh;
  background: #f5f5f5
    url(https://oss.mcloud.moveclub.cn/2025/mv/bg.png) no-repeat;
  background-position: center top;
  background-size: contain;
  box-sizing: border-box;
}

.header {
  width: 100%;
  box-sizing: border-box;
  padding: 96rpx 24rpx 0;
}

.user-info-area {
  width: 100%;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #222222;
  line-height: 50rpx;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #f2f2f2;
  flex-shrink: 0;
}

.info {
  margin-left: 20rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.nickname {
  font-size: 34rpx;
  font-weight: 500;
  color: #111111;
  line-height: 48rpx;
  word-break: break-all;
}

.mobile {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 34rpx;
  word-break: break-all;
}

.container {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 24rpx 40rpx;
}

.card {
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.message {
  position: relative;
  width: 100%;
  min-height: 64rpx;
  background: #77d4ce;
  border-radius: 10rpx;
  box-sizing: border-box;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.message > view:first-child {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
}

.message > view:first-child image {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.message > view:first-child text {
  font-size: 24rpx;
  color: #0e4d4c;
  line-height: 34rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message > view:nth-child(2) {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.message > view:nth-child(2) text {
  font-size: 24rpx;
  color: #0e4d4c;
  line-height: 34rpx;
}

.triangle-up {
  position: absolute;
  left: 34rpx;
  bottom: -10rpx;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 10rpx solid #77d4ce;
}

.points {
  width: 100%;
  background: linear-gradient(90deg, #101820 0%, #18222c 100%);
  border-radius: 18rpx;
  box-sizing: border-box;
  padding: 24rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.points > view:first-child {
  display: flex;
  align-items: center;
  min-width: 0;
}

.points > view:first-child image {
  width: 76rpx;
  height: 76rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.points > view:first-child > view {
  display: flex;
  align-items: baseline;
}

.points > view:first-child > view text:first-child {
  font-size: 52rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1;
}

.points > view:first-child > view text:last-child {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 10rpx;
}

.points > view:last-child {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.points > view:last-child view {
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.points > view:last-child view:first-child {
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  margin-right: 16rpx;
}

.points > view:last-child view:last-child {
  color: #2a3b2f;
  background: #edf9eb;
}

.camp-bind {
  width: 100%;
  background: #ffffff;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.camp-bind-left {
  flex: 1;
  min-width: 0;
}

.camp-bind-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.camp-bind-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
  line-height: 44rpx;
}

.camp-bind-action {
  font-size: 26rpx;
  color: #18c3c8;
  line-height: 36rpx;
}

.camp-bind-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 34rpx;
}

.camp-bind-img {
  width: 104rpx;
  height: 104rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.camp-bound {
  width: 100%;
  background: #ffffff;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 24rpx 24rpx 20rpx;
  margin-bottom: 20rpx;
}

.camp-bound-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.camp-bound-top-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.camp-bound-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
  line-height: 44rpx;
  flex-shrink: 0;
}

.camp-bound-subtitle {
  margin-left: 12rpx;
  font-size: 22rpx;
  color: #999999;
  line-height: 32rpx;
  min-width: 0;
}

.camp-bound-btn {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999999;
  line-height: 34rpx;
  flex-shrink: 0;
}

.camp-bound-boxs {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  border-radius: 12rpx;
  overflow: hidden;
}

.camp-stat-item {
  flex: 1;
  height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.camp-stat-item:active {
  background: #f7fafa;
}

.camp-stat-divider {
  width: 1rpx;
  background: #ededed;
  margin: 18rpx 0;
  flex-shrink: 0;
}

.camp-num {
  font-size: 44rpx;
  font-weight: 600;
  color: #18c3c8;
  line-height: 1;
}

.camp-label {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #666666;
  line-height: 1;
  text-align: center;
}

.menu {
  width: 100%;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.recit {
  width: 100%;
  min-height: 92rpx;
  background: #ffffff;
  box-sizing: border-box;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f2f2f2;
}

.recit:last-child {
  border-bottom: none;
}

.recit::after {
  border: none;
}

.recit > view:first-child {
  display: flex;
  align-items: center;
  min-width: 0;
}

.recit > view:first-child image {
  width: 32rpx;
  height: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.recit > view:first-child text {
  font-size: 28rpx;
  color: #222222;
  line-height: 40rpx;
}

.recit > view:last-child {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.recit > view:last-child image {
  width: 28rpx;
  height: 28rpx;
}

button.recit {
  border-radius: 24;
  padding-right: 24rpx;
 /* text-align: left; */ 
}

button.recit .wx-button-hover {
  background: transparent;
}

button.recit[open-type='contact'] {
  margin: 0;
  line-height: normal;
}

@media screen and (max-width: 375px) {
  .points > view:last-child view {
    padding: 0 18rpx;
    font-size: 24rpx;
  }

  .camp-bound-subtitle {
    margin-left: 10rpx;
    font-size: 22rpx;
  }

  .camp-num {
    font-size: 40rpx;
  }

  .camp-label {
    font-size: 22rpx;
  }
}