page {
  background: #f5f5f5;
}

.verify-page {
  padding: 30rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
}

.sub-title {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.form-item {
  margin-top: 28rpx;
}

.label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.code-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  min-width: 200rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  background: #191e21;
  color: #fff;
  font-size: 26rpx;
}

.submit-btn {
  margin-top: 40rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  background: #191e21;
  color: #fff;
  font-size: 30rpx;
}

.debug-box {
  margin-top: 20rpx;
  color: #ff4d4f;
  font-size: 24rpx;
}

.form-tip {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
}