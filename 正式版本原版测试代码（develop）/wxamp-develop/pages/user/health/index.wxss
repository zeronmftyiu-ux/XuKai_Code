page{
    background: #f5f5f5;
}
.main{
    display: flex;
    flex-direction: column;
    align-items: center;
    box-sizing: border-box;
    padding: 35rpx;
    padding-bottom: 180rpx;
}
.main .logo{
    /* display: flex;
    align-items: center; */
}
.main .logo>image{
    width: 90rpx;
    height: 90rpx;
}
.main .logo>image:nth-child(2){
    width: 37rpx;
    height: 37rpx;
    margin: 30rpx;
}
.main .title{
    font-size: 36rpx;
    padding-top: 24rpx;
}
.main .list{
    box-sizing: border-box;
    padding-top: 68rpx;
    font-size: 24rpx;
    color: rgba(0, 0, 0, .65);
    width: 100%;
}
.main .list .item{
    margin-bottom: 39rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
}
.main .list .item .desc{
    width: 585rpx;
    box-sizing: border-box;
    padding-left: 74rpx;
    position: relative;
}
.main .list .item .desc::before{
    position: absolute;
    width: 10rpx;
    height: 10rpx;
    border-radius: 50%;
    content: ' ';
    background: #B5B5B5;
    left: 44rpx;
    top: 15rpx;
}
.main .list .item .cent{
    width: 32rpx;
    height: 32rpx;
    align-self: flex-start;
}
.main .list .item .check{
    background: url(https://oss.mcloud.moveclub.cn/2025/mv/check.png) no-repeat;
    background-size: 100%;
}
.main .list .item .uncheck{
    background: url(https://oss.mcloud.moveclub.cn/2024/movewell/uncheck.png) no-repeat;
    background-size: 100%;
}
.main .notice{
    font-size: 24rpx;
    color: rgba(0, 0, 0, .65);
    width: 604rpx;
}
.footer{
    width: 100%;
    height: 180rpx;
    background: #ffffff;
    box-shadow: inset 0px 1rpx 0px 0px rgba(229,229,229,1);
    position: fixed;
    bottom: 0;
    left: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-sizing: border-box;
    padding: 10rpx 35rpx;
    padding-bottom: constant(safe-area-inset-bottom); /* 兼容 iOS 11.0-11.2 */
    padding-bottom: env(safe-area-inset-bottom);
}
.mvbutton{
    width: 307rpx;
    height: 96rpx;
    line-height: 96rpx;
    text-align: center;
    color: #ffffff;
    background: #00C7C7;
    border: 2rpx solid #00C7C7;
    border-radius: 10rpx;
    font-size: 36rpx;
}
.cencel{
    color: #ffffff;
    background: #ECECEC;
    border: 2rpx solid rgba(208,208,208,1);
    color: #565656;
}