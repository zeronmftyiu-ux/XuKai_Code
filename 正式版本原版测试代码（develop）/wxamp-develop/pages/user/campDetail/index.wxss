page {
  background: #f7f8fa;
}

.detail-page {
  padding: 16rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.camp-switch-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.camp-switch-list {
  display: flex;
  align-items: center;
}

.camp-switch-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  background: #ffffff;
  border: 1rpx solid #eceff3;
  color: #5f6b7a;
  font-size: 26rpx;
  box-sizing: border-box;
}

.camp-switch-item.active {
  background: #ff8f4a;
  border-color: #ff8f4a;
  color: #ffffff;
  font-weight: 600;
}

.section-title {
  margin: 28rpx 0 16rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #17324d;
  line-height: 1.3;
}

/* 进行中 */
.hero-card {
  background: linear-gradient(180deg, #fff2e4 0%, #fbe8d6 100%);
  border: 1rpx solid #f1d8bf;
  border-radius: 28rpx;
  padding: 24rpx 24rpx 22rpx;
  box-sizing: border-box;
  margin-bottom: 6rpx;
}

.hero-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-stage {
  font-size: 26rpx;
  color: #7a8797;
  font-weight: 600;
}

.hero-status {
  min-width: 112rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #4d5f73;
  font-size: 24rpx;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 32rpx;
  line-height: 1.35;
  color: #17324d;
  font-weight: 700;
  word-break: break-all;
}

.hero-company {
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: #17324d;
  font-weight: 600;
}

.hero-tip {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #556578;
}

.hero-task-list {
  margin-top: 22rpx;
}

.hero-task-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.hero-task-item:last-child {
  margin-bottom: 0;
}

.hero-task-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff8f4a;
  margin-right: 16rpx;
  margin-top: 14rpx;
  flex-shrink: 0;
}

.hero-task-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #556578;
}

.hero-btn-row {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
}

.hero-btn {
  min-width: 188rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 22rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.hero-btn-primary {
  background: #ff8f4a;
  color: #ffffff;
  margin-right: 20rpx;
}

.hero-btn-secondary {
  background: #f3f4f6;
  color: #17324d;
  border: 1rpx solid #d8dde5;
}

.metric-row {
  display: flex;
  justify-content: space-between;
}

.metric-card {
  width: 222rpx;
  background: #ffffff;
  border: 1rpx solid #edf0f4;
  border-radius: 24rpx;
  padding: 22rpx 20rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 10rpx rgba(23, 50, 77, 0.02);
}

.metric-top {
  display: flex;
  align-items: center;
}

.metric-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff8f4a;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.metric-label {
  font-size: 24rpx;
  color: #7b8796;
  line-height: 1.4;
}

.metric-value {
  margin-top: 16rpx;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 700;
  color: #17324d;
}

.metric-unit {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7b8796;
}

.panel-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(23, 50, 77, 0.03);
}

.summary-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.summary-title {
  flex: 1;
  padding-right: 18rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #17324d;
  font-weight: 700;
}

.summary-tag {
  min-width: 104rpx;
  height: 46rpx;
  line-height: 46rpx;
  text-align: center;
  border-radius: 23rpx;
  background: #fff1e7;
  color: #ff8f4a;
  font-size: 22rpx;
  flex-shrink: 0;
}

.summary-sub {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #7b8796;
}

.progress-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
}

.progress-label,
.progress-value {
  font-size: 26rpx;
  color: #6f7d8d;
}

.progress-bar {
  width: 100%;
  height: 14rpx;
  border-radius: 7rpx;
  background: #ece8e3;
  overflow: hidden;
  margin-top: 14rpx;
}

.progress-inner {
  height: 100%;
  border-radius: 7rpx;
  background: #ff8f4a;
}

.summary-grid {
  display: flex;
  margin-top: 24rpx;
  padding-top: 6rpx;
}

.summary-grid-item {
  flex: 1;
}

.summary-grid-label {
  font-size: 24rpx;
  color: #7b8796;
  line-height: 1.4;
}

.summary-grid-text {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1.4;
  color: #17324d;
  font-weight: 600;
  word-break: break-all;
}

.task-card,
.rank-card {
  padding-top: 6rpx;
}

.task-item,
.rank-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f1f3f6;
}

.task-item:last-child,
.rank-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.task-main,
.rank-main {
  flex: 1;
  padding-right: 18rpx;
}

.task-title,
.rank-name {
  font-size: 32rpx;
  line-height: 1.4;
  color: #17324d;
  font-weight: 600;
}

.task-desc,
.rank-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #7f8895;
}

.task-btn,
.rank-badge {
  min-width: 88rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 24rpx;
  background: #19c3c8;
  color: #ffffff;
  font-size: 22rpx;
  flex-shrink: 0;
}

.small-card {
  margin-top: 20rpx;
}

.small-card-title {
  font-size: 32rpx;
  line-height: 1.4;
  color: #17324d;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.small-card-desc {
  font-size: 28rpx;
  line-height: 1.6;
  color: #17324d;
}

.full-action-btn {
  margin-top: 20rpx;
  width: 100%;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 28rpx;
  background: #16c7cc;
  color: #ffffff;
  font-size: 24rpx;
}

.sign-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f3f6;
}

.sign-item:last-of-type {
  border-bottom: none;
  padding-bottom: 0;
}

.sign-title {
  font-size: 30rpx;
  line-height: 1.4;
  color: #17324d;
  font-weight: 600;
}

.sign-time {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #7f8895;
}

.rank-my {
  font-size: 28rpx;
  line-height: 1.5;
  color: #17324d;
  margin-bottom: 8rpx;
}

/* 历史详情 */
.history-hero-card {
  position: relative;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx 24rpx 24rpx;
  box-sizing: border-box;
  border: 1rpx solid #e7ddd2;
  box-shadow: 0 4rpx 14rpx rgba(23, 50, 77, 0.03);
  overflow: hidden;
}

.history-hero-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 8rpx;
  border-radius: 0 8rpx 8rpx 0;
  background: #5f90d9;
}

.history-hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 8rpx;
}

.history-hero-title {
  flex: 1;
  padding-right: 20rpx;
  font-size: 34rpx;
  line-height: 1.35;
  color: #17324d;
  font-weight: 700;
  word-break: break-all;
}

.history-hero-tag {
  min-width: 124rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 24rpx;
  background: #eef3fb;
  color: #5f90d9;
  font-size: 22rpx;
  flex-shrink: 0;
}

.history-hero-subtitle {
  margin-top: 14rpx;
  padding-left: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #607487;
}

.history-data-row {
  display: flex;
  justify-content: space-between;
  margin-top: 26rpx;
  padding-left: 8rpx;
}

.history-data-card {
  width: 200rpx;
  background: #eef3fb;
  border-radius: 22rpx;
  padding: 20rpx 18rpx;
  box-sizing: border-box;
}

.history-data-label {
  font-size: 24rpx;
  line-height: 1.4;
  color: #7b8796;
}

.history-data-value {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #5f90d9;
  font-weight: 700;
}

.history-data-link {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #5f90d9;
  font-weight: 700;
}

.history-result-entry {
  margin-top: 28rpx;
  padding-left: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-result-text {
  font-size: 28rpx;
  line-height: 1.5;
  color: #4f6480;
  font-weight: 600;
}

.history-result-arrow {
  font-size: 40rpx;
  line-height: 1;
  color: #7b8796;
}

.history-summary-title {
  font-size: 30rpx;
  line-height: 1.4;
  color: #17324d;
  font-weight: 700;
}

.history-summary-desc {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #607487;
}

.history-progress-head {
  margin-top: 24rpx;
}

.history-progress-inner {
  background: #5f90d9;
}

.history-rank-badge {
  background: #5f90d9;
}

@media screen and (max-width: 375px) {
  .hero-title,
  .history-hero-title {
    font-size: 30rpx;
  }

  .metric-card {
    width: 214rpx;
  }

  .history-data-card {
    width: 192rpx;
  }

  .metric-value {
    font-size: 50rpx;
  }

  .summary-grid-text {
    font-size: 28rpx;
  }
}

.weight-trend-card {
  padding: 24rpx 24rpx 20rpx;
}

.weight-trend-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.weight-trend-left {
  flex: 1;
  min-width: 0;
}

.weight-trend-label {
  font-size: 24rpx;
  color: #7b8796;
  line-height: 1.4;
}

.weight-trend-value {
  margin-top: 10rpx;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 700;
  color: #17324d;
}

.weight-trend-value text {
  margin-left: 6rpx;
  font-size: 24rpx;
  font-weight: 400;
  color: #7b8796;
}

.weight-trend-desc {
  margin-left: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 22rpx;
  background: #e8f8f8;
  color: #11c5c9;
  font-size: 22rpx;
  line-height: 1.2;
  flex-shrink: 0;
}

.weight-trend-canvas-wrap {
  width: 100%;
  height: 320rpx;
}

.weight-trend-canvas {
  width: 100%;
  height: 320rpx;
  display: block;
}

.weight-trend-canvas-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.weight-trend-canvas {
  width: 100%;
  height: 320rpx;
  display: block;
}

.camp-point-tooltip {
  position: absolute;
  z-index: 3;
  width: 112px;
  padding: 12px 0 10px;
  background: #ffffff;
  border-radius: 12px;
  box-shadow: 0 6px 18px rgba(31, 46, 77, 0.12);
  transform: translateX(-50%);
  text-align: center;
  pointer-events: none;
  box-sizing: border-box;
}

.camp-point-tooltip-weight {
  font-size: 20px;
  line-height: 1.2;
  font-weight: 700;
  color: #11c5c9;
}

.camp-point-tooltip-date {
  margin-top: 6px;
  font-size: 13px;
  line-height: 1.2;
  color: #1d2a3a;
}