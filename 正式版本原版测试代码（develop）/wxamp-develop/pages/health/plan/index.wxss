/* pages/health/plan/index.wxss */
page{
    background: #F4F6F9;
    box-sizing: border-box;
    padding: 24rpx;
}

.item{
    background: #FFFFFF;
    border-radius: 20rpx;
    width: 100%;
    box-sizing: border-box;
    padding: 24rpx 30rpx;
    margin-bottom: 24rpx;
}
.title{
    display: flex;
    justify-content: space-between;
    font-size: 27rpx;
    color: #30292C;
    padding-bottom: 47rpx;
}
.title>view:nth-child(2){
    align-self: flex-start;
}
.bi{
    padding-top: 30rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.bi>view{
    display: flex;
    flex-direction: column;
    align-items: center;
}
.bi>view>view:nth-child(2){
    font-size: 32rpx;
    color: #30292C;
    font-weight: 600;
    padding-top: 16rpx;
}
.bi .start{
    font-size: 27rpx;
    color: #64656B;
    box-sizing: border-box;
    padding: 6rpx 12rpx;
    background: #ECEDF2;
    border-radius: 5rpx;
}
.bi .mid{
    font-size: 27rpx;
    color: #00BDA7;
    box-sizing: border-box;
    padding: 6rpx 12rpx;
    background: #E8F7F6;
    border-radius: 5rpx;
}
.bottom{ 
    height: 60rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 32rpx;
    color: #00BDA7;
    font-weight: 600;
    margin: 16rpx 0 0 0;
    padding: 16rpx 0 0 0;
    border-top: 1rpx solid #ECECED;
}

.footer{
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    height: 130rpx;
    background: #FFFFFF;
    box-shadow: 0rpx -2rpx 12rpx 0rpx rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
}
.footer .confirmbt{
    background: #00C7C7;
    border-radius: 60rpx;
    width: 80%;
    height: 88rpx;
    font-size: 32rpx;
    color: #FFFFFF;
    text-align: center;
    font-weight: 400;
    display: flex;
    align-items: center;
    justify-content: center;
}

.expirelogo{
    width: 120rpx;
    height: 100rpx;
}