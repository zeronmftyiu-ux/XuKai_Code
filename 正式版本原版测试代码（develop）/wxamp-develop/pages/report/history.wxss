page{
    background-color: #F2F5F7;
    box-sizing: border-box;
    padding: 40rpx 30rpx;
}

.header{
    display: flex;
    align-items: center;
    margin-bottom: 20rpx;
}
.header .pdficon{
    width: 56rpx;
    height: 56rpx;
}
.header .title{
    font-size: 36rpx;
    font-weight: 500;
    color: #121F34;
    margin-left: 12rpx;
    padding-bottom: 4rpx;
}

.main{
    background: rgb(255, 255, 255, .57);
    box-shadow: 0px 2rpx 16rpx 0px rgba(203,225,220,0.5);
    border-radius: 12rpx;
    box-sizing: border-box;
    padding: 30rpx 26rpx 48rpx 56rpx;
}

.list{
    margin-bottom: 36rpx;
    position: relative;
}
.list::before{
    position: absolute;
    left: -33rpx;
    top: 10rpx;
    width: 24rpx;
    height: 251rpx;
    content: ' ';
    background: url(https://oss.mcloud.moveclub.cn/2025/mv/%E4%BD%93%E6%A3%80%E6%8A%A5%E5%91%8Ah5/ic.png) no-repeat;
    background-size: 100%;
}
.list .title{
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 30rpx;
    color: #171F3B;
    letter-spacing: -0.2rpx;
    line-height: 42rpx;
    font-weight: 500;
    padding-bottom: 16rpx;
}
.list .item {
    background: #EDF8F7;
    border-radius: 32rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-sizing: border-box;
    padding: 30rpx 29rpx 33rpx;
}
.list .item>view:first-child{
    font-size: 24rpx;
    color: #6D8288;
    font-weight: 400;
}

.list .item>view:first-child>view:first-child{
    font-size: 28rpx;
    color: #171F3B;
    font-weight: 500;
    padding-bottom: 24rpx;
    display: flex;
}

.list .item>view:first-child>view:nth-child(2)>view:first-child{
    padding-bottom: 18rpx;
}

.list .item>view:nth-child(2) {
    width: 140rpx;
    height: 140rpx;
}

.list .item>view:nth-child(2) image{
    width: 100%;
    height: 100%;
}

.error{
    background: linear-gradient(270deg, #FFFFFF 33%, #FFF0F0 100%) !important;
    border: 1rpx solid rgba(255,0,0,1) !important;
}