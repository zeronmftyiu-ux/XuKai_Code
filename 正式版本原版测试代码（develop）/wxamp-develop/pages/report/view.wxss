page{
    background-color: #F2F5F7;
    box-sizing: border-box;
    /* padding: 20rpx 30rpx 24px; */
}
.flat{
    background-color: #F2F5F7;
    box-sizing: border-box;
    padding: 20rpx 30rpx 0px;
}
.top2{
    display: flex;
    align-items: center;
    font-size: 28rpx;
    color: #7682A8;
    font-weight: 400;
    padding: 0 0 24rpx 4rpx;
}
.header{
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 12rpx;
}
.header>view:first-child{
    display: flex;
    align-items: center;
    font-size: 36rpx;
    color: #121F34;
    font-weight: 500;
}
.header>view:nth-child(2){
    display: flex;
    align-items: center;
    font-size: 24rpx;
    color: #7D869B;
    font-weight: 400;
}
.header image{
    width: 50rpx;
    height: 50rpx;
}
.tabs{
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 34rpx;
}
.tabs .tab{
    width: 218rpx;
    height: 97rpx;
    background: #FFFFFF;
    border-radius: 22rpx;
    box-sizing: border-box;
    padding: 10rpx 24rpx;
}
.tab>view:first-child{
    font-size: 30rpx;
    color: #121F34;
    font-weight: 500;
    padding-bottom: 10rpx;
}
.tab>view:nth-child(2){
    font-size: 24rpx;
    color: #7D869B;
    font-weight: 400;
}

.tab text{
    color: #00C7C7;
}

.active{
    position: relative;
    background: #00C7C7 !important;
    color: #FFFFFF !important;
}

.active::after {
  content: '';
  position: absolute;
  bottom: -15rpx;
  left: 50%;
  transform: translateX(-50%); /* 水平居中 */
  /* 使用 border 制造倒三角 */
  width: 0;
  height: 0;
  border-left: 15rpx solid transparent;
  border-right: 15rpx solid transparent;
  border-top: 15rpx solid #00C7C7;    /* 三角形朝下，用 border-top */
  border-bottom: none;
}
.active>view{
    color: #FFFFFF !important;
}
.active text{
   color: #FFFFFF !important; 
}

.main{
    background: #FFFFFF;
    border-radius: 22rpx;
    box-sizing: border-box;
    padding: 22rpx 30rpx;
    margin: 0 30rpx;
}
.list{
    box-sizing: border-box;
    padding-top: 28rpx;
}

.list .title{
    display: flex;
    align-items: center;
    font-size: 32rpx;
    color: #00C7C7;
    font-weight: 600;
    padding-bottom: 14rpx;
}
.list .title>view:first-child{
    padding-right: 18.5rpx;
    display: flex;
    align-items: center;
}
.list .title>view:first-child image{
    width: 55rpx;
    height: 40rpx;
    margin-right: 23rpx;
}
.list .title .bord{
    flex: 1;
    border: 1rpx dashed rgba(216,216,216,1);
    
}
.list .item .i-title{
    font-size: 30rpx;
    color: #121F34;
    font-weight: 600;
    display: flex;
    align-items: center;
    padding-top: 28rpx;
    padding-bottom: 28rpx;
}

.list .item .i-title .i{
    background: #00C7C7;
    border-radius: 4rpx;
    font-size: 22rpx;
    color: #FFFFFF;
    font-weight: 500;
    box-sizing: border-box;
    padding: 1rpx 10rpx;
    margin-right: 16rpx;
    line-height: 30rpx;
}
.list .item .icon{
    background: #DDEEEE;
    border-radius: 32rpx 32rpx 32rpx 4rpx;
    font-size: 28rpx;
    color: #0C2037;
    font-weight: 500;
    box-sizing: border-box;
    padding: 11rpx 25rpx;
    margin-bottom: 24rpx;
    display: inline-block;
}

.list .item .citem{    
    box-sizing: border-box;
    padding-left: 65rpx;
}

.list .item .citem .c-item{
    position: relative;
    font-size: 28rpx;
    color: #121F34;
    line-height: 44rpx;
    font-weight: 400;
    padding-bottom: 20rpx;
}
.list .item .citem .c-item::before{
    position: absolute;
    left: -24rpx;
    content: '•';
    width: 25rpx;
    height: 44rpx;
    font-size: 28rpx;
    color: #121F34;
    line-height: 44rpx;
    font-weight: 600;
}
.list .item .citem .c-item>text{
    font-size: 28rpx;
    color: #121F34;
    line-height: 44rpx;
    font-weight: 600;
}
.list .item .citem .c-item .cc-item{
    box-sizing: border-box;
    padding-left: 60rpx;
    position: relative;
    font-size: 28rpx;
    color: #121F34;
    line-height: 44rpx;
    font-weight: 400;
}
.list .item .citem .c-item .cc-item::before{
    position: absolute;
    left: 24rpx;
    content: '◦';
    width: 25rpx;
    height: 44rpx;
    font-size: 28rpx;
    color: #121F34;
    line-height: 44rpx;
    font-weight: 700;
}
.list .item:last-child .citem .c-item:last-child{
    padding-bottom: 14rpx;
}
.list .body{
    box-sizing: border-box;
    padding: 28rpx 0 14rpx;
}
.list .body .item2{
    display: flex;
    margin-bottom: 20rpx;
    font-size: 28rpx;
    color: #121F34;
    line-height: 44rpx;
    font-weight: 400;
}
.list .body .item2 text{
    font-size: 30rpx;
    color: #121F34;
    font-weight: 600;
}
.list .body .item2:last-child  {
    margin-bottom: 0rpx;
}
.list .item2 .i-title{
    /* display: flex; */
    /* align-items: center; */
    /* justify-content: center; */
    margin-right: 16rpx;
    padding-top: 6rpx;
}
.list .item2 .i{
    background: #00C7C7;
    border-radius: 4rpx;
    font-size: 22rpx;
    color: #FFFFFF;
    font-weight: 500;
    box-sizing: border-box;
    padding: 1rpx 10rpx;
    line-height: 30rpx;
}
.list .item2 .citem{
    flex: 1;
}