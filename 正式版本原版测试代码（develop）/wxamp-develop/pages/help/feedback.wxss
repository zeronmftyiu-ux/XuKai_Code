page{
	background: #F4F6F9;
}

.top{
	background: #fff;
    padding: 8rpx 28rpx 8rpx 38rpx;
    margin: 0 0 20rpx 0;
}
.top .titleimg{
    width: 684rpx;
    height: 226rpx;
}

.body{ 
    background: #fff;
    padding: 8rpx 28rpx 8rpx 38rpx;
    margin: 0 0 20rpx 0;
}
.body .input{
    margin: 24rpx 16rpx 42rpx;
    padding: 20rpx;
    background: #F4F6F9;
    border-radius: 12rpx;
    height: 180rpx;
    width: 88%;
    font-size: 26rpx;
    color: #000000;
    letter-spacing: 0;
    line-height: 32rpx;
    font-weight: 400;
}

.title{
    display: flex;
    margin: 20rpx 0;
}
.label{
    font-size: 32rpx;
    color: #262626;
    letter-spacing: 0;
    font-weight: 500;
}
.typelist{ 
    display: flex;
    justify-content: space-around;
    margin: 0 0 40rpx 0;
}
.typelist .item{ 
    font-size: 26rpx;
    color: #90A09E;
    letter-spacing: 0;
    line-height: 32rpx;
    font-weight: 400;
    width: 146rpx;
    height: 58rpx;
    background: #FFFFFF;
    border: 1px solid rgba(213,212,212,1);
    border-radius: 4px;
    display: flex;
    justify-content: center;
    align-items: center;
}
.typelist .item.active{
    border: 1px solid rgba(0,199,199,1);
    color: #61656C;
} 

.xinghao{
    font-size: 28rpx;
    color: #FF1313;
    letter-spacing: 0;
    font-weight: 400;
    margin: 0 10rpx 0 0;
}

.footer{
    display: flex;
    justify-content: center;
    padding: 24rpx 48rpx;
    position: fixed;
    bottom: 0;
    z-index: 100;
    left: 0;
    right: 0;
    background: #FFFFFF;
    box-shadow: 0rpx -2rpx 12rpx 0rpx rgba(0,0,0,0.1);
}
.footer .btn{
    background: #00C7C7;
    border-radius: 50rpx;
    padding: 25rpx 254rpx;
    font-size: 36rpx;
    color: #FFFFFF;
    text-align: center;
    font-weight: 400;
}