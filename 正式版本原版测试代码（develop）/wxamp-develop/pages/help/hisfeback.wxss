page{
	background: #F4F6F9;
    box-sizing: border-box;
    padding: 24rpx 30rpx;
}

.toptitle{ 
    font-size: 32rpx;
    color: #61656C;
    letter-spacing: 0;
    font-weight: 400;
}

.card{
    background: #FFFFFF;
    border-radius: 20px;
    margin: 24rpx 0;
    padding: 24rpx 30rpx;
}
.card .body{
    padding: 4rpx;
}
.card .body .item{
    display: flex;
    margin-bottom: 30rpx;
}
.card .body .item .title{
    margin: 0 24rpx 0 0;
    font-size: 26rpx;
    color: #90A09E;
    letter-spacing: 0;
    line-height: 32rpx;
    font-weight: 400;
    white-space: nowrap;
}
.card .body .item .content{
    font-size: 26rpx;
    color: #333333;
    letter-spacing: 0;
    line-height: 32rpx;
    font-weight: 400;
}
.card .recardfeed{
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 0 0 4rpx 0;
}
.card .recardfeed .text{ 
    font-size: 24rpx;
    color: #6C7C79;
    letter-spacing: 0;
    line-height: 32rpx;
    font-weight: 400;
    display: flex;
    justify-content: center;
    align-items: center;
    background: #E7F6F3;
    border-radius: 12rpx;
    height: 60rpx;
    width: 91%;
}