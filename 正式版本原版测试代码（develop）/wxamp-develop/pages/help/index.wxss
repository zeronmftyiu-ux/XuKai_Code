page{
    background: #F4F6F9;
}

.title{
    width: 100%;
    display: flex;
    background: #FFFFFF;
}
.title .tab{ 
    width: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20rpx 0 0 0;
}
.title .text{
    opacity: 0.25;
    font-size: 32rpx;
    color: #000000;
    text-align: center;
    font-weight: 400;
    height: 66rpx;
    width: 36%;
}
.title .text.active{
    opacity: 0.85;
    font-family: PingFangSC-Regular;
    font-size: 32rpx;
    color: #000000;
    text-align: center;
    font-weight: 400;
    border-bottom: 5rpx solid #00C7C7;
}

.body{ 
    box-sizing: border-box;
    padding: 20rpx 0 0 0;
}

.footer{
    background: #FFFFFF;
    box-shadow: 0px -1rpx 4rpx 0rpx rgba(212,216,225,1);
    width: 100%;
    display: flex;
    height: 108rpx;
    position: fixed;
    bottom: 0;
}
.footer .icon{
    width: 60rpx;
    height: 60rpx;
}
.footer .left{ 
    width: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
}
.footer .right{ 
    width: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
}