<van-cell-group border="{{ false }}" custom-class="vangroup">
  <van-field
    value="{{ phone }}"
    center
    clearable
    placeholder="请输入手机号"
    border="{{ false }}"
    use-button-slot
    bind:change="onPhoneChange"
  >
    <van-button slot="button" size="small" bindtap="send">
      {{btntips}}
    </van-button>
  </van-field>
</van-cell-group>
<view class="titlet">验证码</view>
<van-cell-group border="{{ false }}" custom-class="vangroup">
  <van-field
    value="{{ code }}"
    center
    clearable
    placeholder="请输入验证码"
    border="{{ false }}"
    use-button-slot
    bind:change="onCodeChange"
  >
  </van-field>
</van-cell-group>

<view bindtap="verifyDoctor" class="button">登录</view>