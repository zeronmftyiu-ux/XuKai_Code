<image class="loginicon" src="http://oss.mcloud.moveclub.cn/2025/mv/doctor/%E5%8C%BB%E7%94%9Flogin.png" mode="widthFix" />

<view class="title">您好，欢迎登录！</view>

<view class="text">如果您是普通用户，请点击返回到上一页</view>

<view class="titlet">手机号</view>
