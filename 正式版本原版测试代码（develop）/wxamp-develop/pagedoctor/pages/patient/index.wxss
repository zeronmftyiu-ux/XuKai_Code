page {
  background: #F0F6F6;
}

.header {
  background: #FFFFFF;
  box-shadow: 0rpx 4rpx 12rpx 0rpx rgba(200,230,227,0.5);
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 30rpx 8rpx;
}
.header .top{ 
    display: flex;
    align-items: center;
}
.header .top .topchild{
    display: flex;
}
.header .top .avatar{
    width: 86rpx;
    height: 86rpx;
    border-radius: 42rpx;
    margin-right: 24rpx;
}
.header .top .name{
    align-items: center;
    display: flex;
    font-size: 30rpx;
    color: #333333;
    font-weight: 600;
    padding-right: 12rpx;
}
.header .top .tag{
    margin-left: 12rpx;
    border-radius: 8rpx;
    font-size: 22rpx;
    line-height: 34rpx;
    font-weight: 400;
    white-space: nowrap;
    padding: 8rpx 12rpx;
    height: 32rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #3ED4A7;
    background: #EFFBF7;
}
.header .top .green{
    color: #3ED4A7;
    background: #EFFBF7;
}
.header .top .red{
    background: #FFF2F1;
    color: #FA746B;
}
.header .top .yellow{
    background: #FFFAE3;
    color: #FFD14B;
}

.accordion {
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}
.accordion .accordion-header {
  padding: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: transform 0.3s ease;
}
.accordion .accordion-header .shoufengqin {
  background: #000000;
  border-radius: 9rpx;
  width: 40rpx;
  height: 6rpx;
}
.accordion .arrow {
  width: 30rpx;
  height: 30rpx;
  transition: transform 0.3s ease;
}
.accordion .arrow.open {
  transform: rotate(180deg);
}
.accordion .accordion-content {
  transition: height 0.3s ease;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 0 0 100rpx;
}
.accordion .content-inner1 {
    display: flex;
}
.accordion .content-inner2 {
    display: flex;
}
.accordion .text1 {
    font-size: 24rpx;
    color: #90A09E;
    font-weight: 400;
    margin-bottom: 4rpx;
}
.accordion .text2 {
    font-size: 24rpx;
    color: #61656C;
    font-weight: 400;
}

.body  { 
    box-sizing: border-box;
    padding: 30rpx 28rpx 100rpx;
}

.body .state { 
    display: flex;
    gap: 20rpx;
    white-space: nowrap;
    margin: 16rpx 0;
}
.state .btn  { 
    border-radius: 32rpx;
    font-size: 28rpx;
    letter-spacing: -0rpx;
    text-align: center;
    padding: 12rpx 24rpx;
}
.state .btn1  { 
    background: #FFFFFF;
    opacity: 0.65;
    color: #000000;
    font-weight: 400;
}
.state .btn2 { 
    background: #00C7C7;
    color: #FFFFFF;
    font-weight: 500;
}


.box{
    background: #FFFFFF;
    border-radius: 20rpx;
    box-sizing: border-box;
    padding: 35rpx;
    margin: 34rpx 0;
    box-shadow: 0px 2px 5px 2px rgba(175,228,220,0.3);
}
.box .month-switch {
    display: flex;
    justify-content: center;
    align-items: center;
    padding-bottom: 38rpx;
}
.box .month-switch .today{
    background: #E8F7F6;
    border-radius: 88%;
    width: 64rpx;
    height: 56rpx;
    align-items: center;
    display: flex;
    justify-content: center;
    font-size: 24rpx;
    margin: 0 -24rpx 0 20rpx;
}
.box .month-switch .title {
    text-align: center;
    font-size: 30rpx;
    color: #000000;
    font-weight: 600;
    padding: 0 32rpx;
}
.box .calendar{
    border-radius: 10rpx;
    box-sizing: border-box;
    padding: 13rpx 0;
}
.box .calendar .weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    font-size: 26rpx;
    color: #30292C;
    font-weight: 400;
    padding-bottom: 20rpx;
}
.box .calendar .days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    font-size: 30rpx;
    color: #30292C;
    text-align: center;
    font-weight: 700;
}
.box .calendar .day {
    background: #E8F7F6;
    border-radius: 50%;
    width: 56rpx;
    height: 56rpx;
    align-items: center;
    justify-content: center;
    display: flex;
    margin: 0 auto;
}
.box .calendar .dayclick  { 
    color: #FFFFFF;
    background: #00C7C7;
}

.box .bottom { 
    width: 100%;
    background: #E8F7F6;
    border-radius: 16rpx;
    box-sizing: border-box;
    padding: 20rpx 28rpx 18rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 24rpx;
    color: #212327;
    margin: 10rpx 0 0 0;
}
.box .bottom .describe{
    display: flex;
    font-size: 24rpx;
    color: #212327;
    font-weight: 400;
    justify-content: space-between;
    margin-bottom: 12rpx;
}
.box .bottom .number{ 
    display: flex;
    align-items: center;
    justify-content: space-around;
}
.box .bottom .number .operator {
    font-size: 28rpx;
    color: #212327;
    width: 15%;
    text-align: center;
    flex-shrink: 0;
}
.box .bottom .number .numberall{ 
    width: 30%;
    font-size: 46rpx;
    color: #FF8D4F;
    letter-spacing: -3.83rpx;
    font-weight: 700;
    margin: 0 36rpx 0 12rpx;
    text-align: center;
}
.box .bottom .number .numberchild{ 
    width: 15%;
    font-size: 28rpx;
    color: #212327;
    letter-spacing: -2.33rpx;
    font-weight: 700;
    margin: 0 8rpx 0 -8rpx;
    text-align: center;
}

