    margin: 0 0 16rpx 0;
}
.title .left{ 
    display: flex;
    width: 50%;
    justify-content: center;
    padding: 20rpx 0;
    font-size: 32rpx;
    color: rgba(255,255,255,0.80);
    letter-spacing: 0;
    font-weight: 900;
    background: url(http://oss.mcloud.moveclub.cn/2025/mv/doctor/%E5%88%87%E6%8D%A22.png) no-repeat;
    background-size: 100% 100%;
}
.title .right{ 
    display: flex;
