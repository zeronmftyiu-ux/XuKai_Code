page{
    background: #F6F6F6;
}
.body{
    display: flex;
    flex-grow: 1;
    overflow: hidden;
    box-sizing: border-box;
    position: relative;
    width: 100%;
    padding-bottom: 150rpx;
}
.list {
    width: 100%;
    flex-grow: 1;
    padding: 20rpx;
    overflow-y: auto;
    border-right: 1rpx solid #ddd;
    display: flex;
    flex-direction: column;
}
.message {
    margin: 5rpx 0;
    padding: 8rpx;
    border-radius: 5rpx;
    max-width: 70%;
    text-align: left; /* 左对齐 */
}
.message>view:first-child{
    font-size: 28rpx;
    color: #61656C;
    letter-spacing: 0;
    font-weight: 600;
    padding-bottom: 14rpx;
}
.message>view:first-child>view:nth-child(2){
    font-size: 24rpx;
    color: #61656C;
    letter-spacing: 0;
    font-weight: 400;
    padding-left: 8rpx;
}

.message image{
    width: 213rpx;
    height: 270rpx;
}

.question {
    /* background-color: #FF6900; */
    align-self: flex-end;
    color: #ffffff;
    margin-right: 92rpx;
    position: relative;
    text-align: right;
}
.question::after{
    position: absolute;
    right: -92rpx;
    top: 0;
    content: ' ';
    background: url(https://oss.mcloud.moveclub.cn/2024/movewell/pc/2.png) no-repeat;
    width: 70rpx;
    height: 70rpx;
    background-size: 100%;
}

.answer {
    /* background-color: #ffffff;
    border: 2rpx solid rgba(228,223,234,1); */
    align-self: flex-start;
    color: #505862;
    margin-left: 92rpx;
    position: relative;
}
.answer::before{
    position: absolute;
    left: -92rpx;
    top: 0;
    content: ' ';
    background: url(https://oss.mcloud.moveclub.cn/2024/movewell/%E6%AF%8F%E5%B0%8F%E6%AD%A5%402x.png) no-repeat;
    width: 70rpx;
    height: 70rpx;
    background-size: 100%;
}

.boxs{
    background: #00C7C7;
    border-radius: 24rpx;
    box-sizing: border-box;
    padding: 12rpx 18rpx;
    color: #ffffff;
    display: inline-block;
}

.boxa{
    background: #FFFFFF;
    border: 2rpx solid rgba(228,223,234,1);
    border-radius: 24rpx;
    box-sizing: border-box;
    padding: 12rpx 18rpx;
    display: inline-block;
}

.time{
    text-align: center;
    box-sizing: border-box;
    padding: 18rpx 24rpx;
    font-size: 24rpx;
    color: #90A09E;
    width: 380rpx;
    align-self: center;
    margin: 16rpx 0;
}

.footer{
    background: #FFFFFF;
    box-shadow: inset 0px 1rpx 0px 0px rgba(229,229,229,1);
    width: 100%;
    height: 122rpx;
    position: fixed;
    left: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-sizing: border-box;
    padding: 0 24rpx;
}
.footer .input{
    width: 450rpx;
    height: 80rpx;
    background: #F9F9F9;
    border: 4rpx solid #00C7C7;
    border-radius: 10rpx;
    box-sizing: border-box;
    padding: 0 24rpx;
}
.footer image{
    width: 80rpx;
    height: 80rpx;
}

.footer .btn{
    width: 111rpx;
    height: 64rpx;
    line-height: 64rpx;
    text-align: center;
    background: #00C7C7;
    border-radius: 10rpx;
    font-size: 24rpx;
    color: #FFFFFF;
}

.footer  .disabled{
    
    background: #C0C3CA;
}