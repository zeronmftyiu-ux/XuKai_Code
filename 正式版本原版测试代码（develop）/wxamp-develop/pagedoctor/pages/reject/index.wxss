.title{ 
    display: flex;
    box-sizing: border-box;
    padding: 52rpx 48rpx 48rpx;
}
.title .avatar{
    width: 86rpx;
    height: 86rpx;
    border-radius: 42rpx;
}
.title .info{
    display: flex;
    flex-direction: column;
    margin: 0 0 0 32rpx;
    width: 80%;
}
.title .title1{ 
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 0 0 8rpx 0;
}
.title .title1 .name{ 
    font-size: 32rpx;
    color: #333333;
    font-weight: 600;
}
.title .title1 .icon{
    background: #FFF2F0;
    border-radius: 6rpx;
}
.title .title2{ 
    display: flex;
}
.title .title2 .time1{
    font-size: 24rpx;
    color: #90A09E;
    font-weight: 400;
}
.title .title2 .time2{
    font-size: 24rpx;
    color: #333333;
    font-weight: 400;
}

.body{
    height: 100%;
    padding: 0 0 15% 0;
}

.state{ 
    font-size: 32rpx;
    color: #262626;
    font-weight: 500;
    background: #F0F6F6;
    padding: 40rpx 48rpx;
}

.card{ 
    padding: 40rpx 48rpx;
    display: flex;
    margin-bottom: 8rpx;
    
}
.card .left{
    font-size: 26rpx;
    color: #90A09E;
    line-height: 34rpx;
    font-weight: 400;
    display: flex;
    flex-direction: column;
    gap: 40rpx;
}
.card .right{
    margin-left: 15%;
    opacity: 0.85;
    font-size: 26rpx;
    color: #000000;
    line-height: 34rpx;
    font-weight: 400;
    display: flex;
    flex-direction: column;
    gap: 40rpx;
} 
.card .tag{
    border: 1rpx solid rgba(0,199,199,1);
    border-radius: 30rpx;
    font-size: 24rpx;
    color: #00C7C7;
    font-weight: 400;
    align-self: flex-start;
    padding: 8rpx 16rpx;
    margin: 8rpx 0 -16rpx;
    width: 120rpx;
}

.footer{
    display: flex;
    justify-content: flex-end;
    padding: 26rpx 44rpx;
    position: fixed;
    bottom: 0;
    z-index: 100;
    left: 0;
    right: 0;
    background: #FFFFFF;
    box-shadow: 0rpx -1rpx 4rpx 0rpx rgba(212,216,225,1);
    gap: 12rpx;
}
.footer .btn{
    background: #00C7C7;
    border-radius: 35rpx;
    padding: 15rpx 38rpx;
    font-size: 28rpx;
    color: #FFFFFF;
    font-weight: 400;
}

.custom-action-sheet {
    margin-bottom: 0px;
}

.selected-tags {
    display: flex;
    padding: 0rpx 4rpx;
}
.selecttag {
    border-radius: 8rpx;
    font-size: 24rpx;
    line-height: 34rpx;
    font-weight: 400;
    white-space: nowrap;
    padding: 4rpx 6rpx;
    color: #3ED4A7;
    background: #EFFBF7;
    margin-right: 8rpx;
}
.green{
    color: #3ED4A7;
    background: #EFFBF7;
}
.red{
    background: #FFF2F1;
    color: #FA746B;
}
.yellow{
    background: #FFFAE3;
    color: #FFD14B;
}

.poptitle {
    font-size: 36rpx;
    color: #000000;
    text-align: center;
    font-weight: 500;
    margin: 35rpx 0rpx;
}
.poplist {
    box-sizing: border-box;
    padding: 10rpx 54rpx;
}
.poplist .checkbox {
    display: flex;
    align-items: center;
    padding: 16rpx 0rpx;
    justify-content: space-between;
}
.poplist .checkbox .icon {
    display: flex;
    gap: 46px;
    padding-right: 20px;
}
.poplist .checkbox .itemname{
    font-size: 32rpx;
    color: #61656C;
    font-weight: 400;
}
.poplist .radio {
    width: 36rpx;
    height: 36rpx;
    border-radius: 50%;
    align-items: center;
    display: flex;
}
.poplist .radiobig {
    width: 56rpx;
    height: 56rpx;
    background: #FFFFFF;
    border-radius: 50%;
    align-items: center;
    display: flex;
    justify-content: center;
}
.popbottom { 
    display: flex;
    justify-content: center;
}
.popbottom .button1 { 
    border: 1rpx solid rgba(207,207,207,1);
    border-radius: 50rpx;
    font-size: 36rpx;
    color: #000000;
    font-weight: 400;
    padding: 12rpx 88rpx;
    margin-right: 48rpx;
}
.popbottom .button2 { 
    border: 1rpx solid rgba(207,207,207,1);
    border-radius: 50rpx;
    font-size: 36rpx;
    color: #FFFFFF;
    font-weight: 400;
    background: #00C7C7;
    padding: 12rpx 88rpx;
}
.van-checkbox__icon {
    border-radius: 8rpx;
}