.search {
  padding: 40rpx 20rpx;
  margin: 12rpx 0;
}  
.custom-search{
  height: 70rpx !important;
}
.van-search__content {
  height: 70rpx !important;
  min-height: auto !important;
  align-items: center !important;
}
.van-field__body input {
  height: 100% !important;
  font-size: 28rpx !important;
}

.body {
  box-sizing: border-box;
  padding: 28rpx 44rpx;
  background: #F9F9F9;
}
.body .title {
  display: flex;
  justify-content: space-between;
  margin: 12rpx 0 16rpx;
}
.body .title1 {
  font-size: 32rpx;
  font-weight: 500;
}
.body .title2 {
  font-size: 30rpx;
  font-weight: 400;
}
.body .right {
  display: flex;
  align-items: center;
  white-space: nowrap;
}
.body .icon {
  width: 46rpx;
  height: 46rpx;
  margin: 0 12rpx;
}

.alllist {
  display: flex;
  flex-direction: column;
  margin: 0 -28rpx;
}
.alllist .list { 
  margin: 10rpx 16rpx;
  padding: 20rpx;
  background: #FFFFFF;
  box-shadow: 0px 2px 12px 0px rgba(0,0,0,0.06);
  border-radius: 20rpx;
  white-space: nowrap;
}
.alllist .list .top{ 
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 100rpx;
    margin: 0rpx 16rpx 10rpx;
    padding-bottom: 10rpx;
}
.alllist .list .bottom{ 
    display: flex;
    align-items: center;
    height: 80rpx;
    margin: 12rpx 16rpx 0;
    justify-content: space-between;
}
.alllist .list .top1{ 
    display: flex;
    align-items: center;
    gap: 12px;
    width: 90%;
    margin: 10rpx 0;
}
.alllist .list .top2{ 
    display: flex;
    flex-direction: column;
}
.alllist .list .arrow{ 
    margin: 0 12rpx 0 0;
    
}
.alllist .list .name{ 
    font-size: 36rpx;
    color: #333333;
    font-weight: 500;
}
.alllist .list .bing{ 
    border-radius: 8rpx;
    font-size: 24rpx;
    line-height: 34rpx;
    font-weight: 400;
    white-space: nowrap;
    padding: 4rpx 6rpx;
}
.alllist .list .green{
    color: #3ED4A7;
    background: #EFFBF7;
}
.alllist .list .red{
    background: #FFF2F1;
    color: #FA746B;
}
.alllist .list .yellow{
    background: #FFFAE3;
    color: #FFD14B;
}
.alllist .list .lasttime{ 
    font-size: 24rpx;
    font-weight: 400;
}
.alllist .list .day{
    display: flex;
    align-items: center;
    gap: 12rpx;
    margin: 0 0 0 50%;
} 
.alllist .list .day1{ 
    font-size: 44rpx;
    color: #333333;
    font-weight: 700;
}
.alllist .list .day2{ 
    font-size: 24rpx;
    color: #61656C;
    font-weight: 300;
}
.alllist .list .day3{ 
    font-size: 26rpx;
    color: #333333;
    font-weight: 300;
    padding: 0 0rpx 0 30rpx;
}
.alllist .list .continue {
    font-size: 24rpx;
    color: #61656C;
    font-weight: 300;
    margin: 0 0 0 25%;
}
.alllist .list .button{
    background: #00C7C7;
    border-radius: 34rpx;
    font-size: 28rpx;
    color: #FFFFFF;
    text-align: center;
    font-weight: 400;
    margin: 0;
    width: 25%;
}
.divider {
  height: 1rpx;
  width: 100%;
  background-color: #E0E0E0 ;
}

.poptitle {
    font-size: 38rpx;
    color: #000000;
    text-align: center;
    font-weight: 500;
    margin: 35rpx 0rpx;
}
.poplist {
    box-sizing: border-box;
    padding: 10rpx 54rpx;
}
.poplist .checkbox {
    display: flex;
    align-items: center;
    padding: 16rpx 0rpx;
    justify-content: space-between;
}
.popbottom { 
    display: flex;
    justify-content: center;
}
.popbottom .button1 { 
    border: 1rpx solid rgba(207,207,207,1);
    border-radius: 50rpx;
    font-size: 36rpx;
    color: #000000;
    font-weight: 400;
    padding: 12rpx 88rpx;
    margin-right: 48rpx;
}
.popbottom .button2 { 
    border: 1rpx solid rgba(207,207,207,1);
    border-radius: 50rpx;
    font-size: 36rpx;
    color: #FFFFFF;
    font-weight: 400;
    background: #00C7C7;
    padding: 12rpx 88rpx;
}