.b-item{
    width: 340rpx;
    /* height: 500rpx; */
    background: #fff;
    border-radius: 8rpx;
    margin-bottom: 21rpx;
}
.b-item image{
    width: 340rpx;
    height: 328rpx;
    border-radius: 8rpx 8rpx 0 0;
}
.b-item .cent{
    position: relative;
    box-sizing: border-box;
    padding: 16rpx 20rpx 12rpx;
    width: 100%;
    /* height: 160rpx; */
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.b-item .cent .tag{
    position: absolute;
    background: linear-gradient(to right, #F88700, #F95902);
    width: auto;
    height: 26rpx;
    line-height: 26rpx;
    box-sizing: border-box;
    padding: 0 10rpx;
    color: #fff;
    text-align: center;
    font-size: 16rpx;
    top: -25rpx;
    left: 20rpx;
    z-index: 1;
    border-radius: 4rpx;
}
.b-item .cent .b-title{
    font-size: 26rpx;
    color: #000;
    display: block;
    opacity: 0.85;
    font-weight: 500;
    /* height: 55rpx; */
    /* padding-bottom: 23rpx; */
}
.b-item .cent .free{
    width: 100%;
    display: flex;
    align-items: center;
    /* justify-content: space-between; */
}
.b-item .cent .free .price{
    color: #FF5F1B;
    font-size: 36rpx;
    font-weight: 500;
}
.b-item .cent .free .price text{
    font-size: 28rpx;
    font-weight: 400;
}
.b-item .cent .free .original{
    font-size: 24rpx;
    color: rgba(0, 0, 0, .45);
    text-decoration: line-through;
    line-height: 34rpx;
    padding-left: 6rpx;
}
.brand{
    opacity: 0.45;
    font-size: 28rpx;
    color: #000000;
    line-height: 34rpx;
    font-weight: 400;
}
.tags{
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    /* padding-bottom: 8rpx; */
}
.tags>view{
    margin-bottom: 10rpx;
}
.tags .vip{
    font-size: 15rpx;
    font-weight: 500;
    color: #964301;
    box-sizing: border-box;
    padding: 3rpx 14rpx 3rpx 18rpx;
    border-radius: 0px 10rpx 10rpx 0px;
    background: linear-gradient(90deg, rgba(254, 177, 71, 1) 0%, rgba(245, 245, 245, 1) 100%);
    position: relative;
    margin-left: 18rpx;
    margin-right: 7rpx;
}
.tags .vip::before{
    content: ' ';
    background: url(https://oss.mcloud.moveclub.cn/movewelfare/2024/icon.png) no-repeat;
    background-size: 100%;
    width: 34rpx;
    height: 30rpx;
    left: -18rpx;
    top: -4rpx;
    position: absolute;
}
.cou{
    background: url(https://oss.mcloud.moveclub.cn/movewelfare/2024/tt.png) no-repeat;
    width: 85rpx;
    height: 25rpx;
    background-size: 100%;
    
}